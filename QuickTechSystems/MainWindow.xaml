<Window x:Class="QuickTechSystems.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickTechSystems.WPF"
        xmlns:views="clr-namespace:QuickTechSystems.WPF.Views"
        xmlns:vm="clr-namespace:QuickTechSystems.WPF.ViewModels"
        mc:Ignorable="d"
        Title="{DynamicResource MainWindow_Title}" 
        Height="800" 
        Width="1200"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="{Binding CurrentFlowDirection}"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="SidebarBackground" Color="#1E293B"/>
        <SolidColorBrush x:Key="ButtonHoverBackground" Color="#334155"/>
        <SolidColorBrush x:Key="CategoryText" Color="#94A3B8"/>
        <SolidColorBrush x:Key="MainBackground" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="ScrollBarThumb" Color="#475569"/>
        <SolidColorBrush x:Key="ScrollBarThumbHover" Color="#64748B"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>

        <!-- Navigation Button Style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="10"
                        BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category Header Style -->
        <Style x:Key="CategoryHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CategoryText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="24,24,5,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- Toggle Button Style -->
        <Style x:Key="ModernToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource SidebarBackground}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="#2D3B4E">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" 
                                                Direction="315"
                                                Opacity="0.2" 
                                                ShadowDepth="3"
                                                Color="#0F172A"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Thumb Style -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{StaticResource ScrollBarThumb}" 
                                CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Style -->
        <Style x:Key="CustomScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Rectangle Width="6" 
                                     Fill="Transparent" 
                                     RadiusX="3" 
                                     RadiusY="3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" 
                                                Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" 
                                                Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer Style -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                     Grid.Column="1"
                                     Value="{TemplateBinding VerticalOffset}"
                                     Maximum="{TemplateBinding ScrollableHeight}"
                                     ViewportSize="{TemplateBinding ViewportHeight}"
                                     Style="{StaticResource CustomScrollBarStyle}"
                                     Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavColumn" Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Panel -->
        <Border x:Name="NavigationPanel"
                Grid.Column="0"
                Background="{StaticResource SidebarBackground}"
                CornerRadius="0,16,16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" 
                                Direction="0"
                                Opacity="0.2" 
                                ShadowDepth="5"
                                Color="#0F172A"/>
            </Border.Effect>
            <DockPanel Margin="0,10">
                <!-- App Header -->
                <StackPanel DockPanel.Dock="Top" 
                          Margin="14,50,24,12">
                    <TextBlock Text="{DynamicResource MainWindow_AppTitle}"
                             Foreground="White"
                             FontSize="26"
                             FontWeight="Bold"
                             TextOptions.TextFormattingMode="Display"/>
                    <TextBlock Text="{DynamicResource MainWindow_AppTitle}"
                             Foreground="{StaticResource CategoryText}"
                             FontSize="15"
                             FontWeight="Medium"
                             Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <ScrollViewer Style="{StaticResource ModernScrollViewer}"
                            DockPanel.Dock="Top" 
                            VerticalScrollBarVisibility="Auto"
                            Margin="0,10">
                    <StackPanel>
                        <!-- Main Operations -->
                        <TextBlock Text="{DynamicResource MainWindow_MainOperations}"
                                 Style="{StaticResource CategoryHeader}"/>
                        <Button Content="Dashboard" 
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Dashboard"/>
                        <Button Content="{DynamicResource MainWindow_Transactions}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Transactions"/>
                        <Button Content="{DynamicResource MainWindow_Products}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Products"/>

                        <!-- Finance -->
                        <TextBlock Text="{DynamicResource MainWindow_Finance}"
                                 Style="{StaticResource CategoryHeader}"/>
                        <Button Content="{DynamicResource MainWindow_CustomerDebt}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="CustomerDebt"/>
                        <Button Content="{DynamicResource MainWindow_Profit}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Profit"/>
                        <Button Content="{DynamicResource MainWindow_Drawer}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Drawer"/>
                        <Button Content="{DynamicResource MainWindow_Expenses}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Expenses"/>

                        <!-- Management -->

                        <Button Content="Monthly Subscriptions" 
        Style="{StaticResource NavButton}"
        Command="{Binding NavigateCommand}" 
        CommandParameter="MonthlySubscriptions"/>
                        <TextBlock Text="{DynamicResource MainWindow_Management}"
                                 Style="{StaticResource CategoryHeader}"/>
                        <Button Content="{DynamicResource MainWindow_Customers}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Customers"/>
                        <Button Content="{DynamicResource MainWindow_Suppliers}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Suppliers"/>
                        <Button Content="{DynamicResource MainWindow_Categories}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Categories"/>
                        <Button Content="{DynamicResource MainWindow_Employees}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Employees"/>

                        <!-- Reports -->
                        <TextBlock Text="{DynamicResource MainWindow_Reports}"
                                 Style="{StaticResource CategoryHeader}"/>
                        <Button Content="{DynamicResource MainWindow_TransactionHistory}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="TransactionHistory"/>
                        <Button Content="{DynamicResource MainWindow_Settings}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Settings"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1"
                Background="{StaticResource MainBackground}"
                Padding="24">
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Border>

        <!-- Toggle Button Overlay -->
        <Grid Panel.ZIndex="999" Grid.ColumnSpan="2">
            <ToggleButton x:Name="ToggleNavButton"
                         Style="{StaticResource ModernToggleButton}"
                         Content="≡"
                         Click="ToggleNavButton_Click"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Margin="12"/>
        </Grid>

        <!-- Global Product Editor Overlay -->
        <Grid x:Name="PART_GlobalProductOverlay" 
      Panel.ZIndex="1001" 
      Grid.ColumnSpan="2" 
      Visibility="Collapsed">
            <Rectangle Fill="Black" Opacity="0.5"/>
            <Border Background="White" 
            Width="600" 
            Height="Auto"
            MaxHeight="700" 
            VerticalAlignment="Center" 
            HorizontalAlignment="Center" 
            Padding="20"
            CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>
                <ContentControl x:Name="PART_ProductEditorContent"/>
            </Border>
        </Grid>
    </Grid>
</Window>