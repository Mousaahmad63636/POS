<Window x:Class="QuickTechSystems.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/design/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickTechSystems.WPF"
        xmlns:views="clr-namespace:QuickTechSystems.WPF.Views"
        xmlns:vm="clr-namespace:QuickTechSystems.WPF.ViewModels"
        mc:Ignorable="d"
        Title="{DynamicResource MainWindow_Title}" 
        Height="800" 
        Width="1200"
        MinWidth="800"
        MinHeight="600"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Loaded="MainWindow_Loaded"
        StateChanged="MainWindow_StateChanged"
        SizeChanged="MainWindow_SizeChanged"
        FlowDirection="{Binding CurrentFlowDirection}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid x:Name="MainGrid" MouseDown="MainGrid_MouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavColumn" Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Panel -->
        <Border Grid.Column="0"
                Background="LightGray"
                BorderBrush="Gray"
                BorderThickness="0,0,1,0"
                x:Name="NavigationPanel">
            <DockPanel Margin="0,10">
                <!-- App Header -->
                <Border DockPanel.Dock="Top" 
                       Padding="20,16"
                       Background="Gray">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MainWindow_AppTitle}"
                                 Foreground="White"
                                 FontSize="26"
                                 FontWeight="Bold"/>

                        <!-- User Info -->
                        <Border Margin="0,16,0,0"
                                Background="DarkGray"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- User Avatar -->
                                <Border Width="40" 
                                        Height="40"
                                        Background="Gray">
                                    <TextBlock Text="{Binding UserInitials}"
                                             Foreground="White"
                                             FontWeight="Bold"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>

                                <!-- User Details -->
                                <StackPanel Grid.Column="1" 
                                          Margin="12,0,0,0">
                                    <TextBlock Text="{Binding CurrentUserName}"
                                             Foreground="White"
                                             FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentUserRole}"
                                             Foreground="White"
                                             Opacity="0.7"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Navigation Menu -->
                <ScrollViewer DockPanel.Dock="Top" 
                            VerticalScrollBarVisibility="Auto"
                            Margin="0,20,0,0">
                    <StackPanel>
                        <!-- Main Operations -->
                        <TextBlock Text="{DynamicResource MainWindow_MainOperations}"
                                 Foreground="Gray"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 Margin="24,20,0,10"/>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Dashboard"
                                IsEnabled="{Binding IsNavigationEnabled}"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Margin="0,0,12,0"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Transactions">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰" Margin="0,0,12,0"/>
                                <TextBlock Text="Transactions"/>
                            </StackPanel>
                        </Button>

                        <!-- Finance Section -->
                        <TextBlock Text="{DynamicResource MainWindow_Finance}"
                                 Foreground="Gray"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 Margin="24,20,0,10"/>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Customers">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" Margin="0,0,12,0"/>
                                <TextBlock Text="Customers"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Drawer">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏦" Margin="0,0,12,0"/>
                                <TextBlock Text="Drawer"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Quotes">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📝" Margin="0,0,12,0"/>
                                <TextBlock Text="Quotes"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Expenses"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💸" Margin="0,0,12,0"/>
                                <TextBlock Text="Expenses"/>
                            </StackPanel>
                        </Button>

                        <!-- Management Section -->
                        <TextBlock Text="{DynamicResource MainWindow_Management}"
                                 Foreground="Gray"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 Margin="24,20,0,10"
                                 Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="TableManagement"
                                IsEnabled="{Binding IsNavigationEnabled}"
                                Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🍽️" Margin="0,0,12,0"/>
                                <TextBlock Text="Table Management"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Products"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" Margin="0,0,12,0"/>
                                <TextBlock Text="Products"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
        Height="46"
        Command="{Binding NavigateCommand}" 
        IsEnabled="{Binding IsNavigationEnabled}"
        CommandParameter="MainStock"
        Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏭" Margin="0,0,12,0"/>
                                <TextBlock Text="Main Stock"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Categories"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" Margin="0,0,12,0"/>
                                <TextBlock Text="Categories"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Suppliers"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚚" Margin="0,0,12,0"/>
                                <TextBlock Text="Suppliers"/>
                            </StackPanel>
                        </Button>

                        <!-- Reports Section -->
                        <TextBlock Text="{DynamicResource MainWindow_Reports}"
                                 Foreground="Gray"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 Margin="24,20,0,10"
                                 Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="TransactionHistory"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Margin="0,0,12,0"/>
                                <TextBlock Text="Transaction History"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Profit"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📈" Margin="0,0,12,0"/>
                                <TextBlock Text="Profit"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="LowStockHistory"
                                Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📉" Margin="0,0,12,0"/>
                                <TextBlock Text="Low Stock History"/>
                            </StackPanel>
                        </Button>

                        <!-- Admin Section -->
                        <TextBlock Text="{DynamicResource MainWindow_Administration}"
                                 Foreground="Gray"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 Margin="24,20,0,10"
                                 Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Settings"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" Margin="0,0,12,0"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,2"
                                Height="46"
                                Command="{Binding NavigateCommand}" 
                                IsEnabled="{Binding IsNavigationEnabled}"
                                CommandParameter="Employees"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" Margin="0,0,12,0"/>
                                <TextBlock Text="Employees"/>
                            </StackPanel>
                        </Button>

                        <!-- Logout Button -->
                        <Button Margin="8,40,8,20"
                                Height="46"
                                Command="{Binding LogoutCommand}"
                                IsEnabled="{Binding IsNavigationEnabled}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" Margin="0,0,12,0"/>
                                <TextBlock Text="Logout" Foreground="Red"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Hide sidebar button -->
        <Button x:Name="HideSidebarButton"
                Width="44"
                Height="44"
                FontSize="24"
                FontWeight="Bold"
                Background="Gray"
                Foreground="White"
                BorderThickness="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,12,0"
                Panel.ZIndex="999"
                Click="HideSidebarButton_Click"
                Grid.Column="0">
            <TextBlock Text="‹"/>
        </Button>

        <!-- Content Area -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="Gray"
                BorderThickness="0,1,1,1"
                Margin="0,10,10,10">
            <Grid>
                <ContentControl Content="{Binding CurrentViewModel}"
                              Margin="20"/>

                <!-- Loading Overlay -->
                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Background="#80FFFFFF">
                    <Border Background="White"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            Width="300">
                        <StackPanel Margin="20" 
                                  VerticalAlignment="Center" 
                                  HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" 
                                       Width="200" 
                                       Height="4"/>
                            <TextBlock Text="{Binding LoadingMessage}"
                                     Margin="0,12,0,0"
                                     FontSize="14"
                                     TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Error Message -->
                <Border Background="LightPink"
                       BorderBrush="Red"
                       BorderThickness="1"
                       Padding="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,20"
                       Panel.ZIndex="999">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" 
                                  TextWrapping="Wrap"
                                  MaxWidth="500"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Hover-activated sidebar reveal area -->
        <Border x:Name="SidebarHoverArea"
                Grid.Column="1" 
                Width="15" 
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Background="Transparent"
                Panel.ZIndex="999"
                Visibility="Collapsed"
                MouseEnter="SidebarHoverArea_MouseEnter"/>

        <!-- Show sidebar button -->
        <Button x:Name="ShowSidebarButton"
                Width="44"
                Height="44"
                FontSize="24"
                FontWeight="Bold"
                Background="Gray"
                Foreground="White"
                BorderThickness="1"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Panel.ZIndex="999"
                Click="ShowSidebarButton_Click"
                Grid.Column="1"
                Visibility="Collapsed">
            <TextBlock Text="›"/>
        </Button>
    </Grid>
</Window>