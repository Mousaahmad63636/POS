<!-- Path: QuickTechSystems.WPF.Views/BulkMainStockDialog.xaml -->
<Window x:Class="QuickTechSystems.WPF.Views.BulkMainStockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:QuickTechSystems.WPF.Views"
        xmlns:converters="clr-namespace:QuickTechSystems.WPF.Converters"
        Title="Bulk Add MainStock Items"
        Height="700" Width="1200"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageConverter"/>
        <converters:FilePathToImageConverter x:Key="FilePathToImageConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Bulk Add MainStock Items" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Bulk Selection Panel -->
        <Expander Grid.Row="1" Header="Bulk Actions" IsExpanded="{Binding ShowBulkSelectionPanel}" Margin="0,0,0,10">
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Category Bulk Selection -->
                <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,10,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Bulk Category Assignment" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" 
                                      ItemsSource="{Binding Categories}" 
                                      SelectedItem="{Binding SelectedBulkCategory}"
                                      DisplayMemberPath="Name"/>
                            <Button Grid.Column="1" Content="+" Command="{Binding AddNewCategoryCommand}" Width="30" Margin="5,0,0,0"/>
                        </Grid>

                        <Button Grid.Row="2" Content="Apply to All Items" Command="{Binding ApplyBulkCategoryCommand}"/>
                    </Grid>
                </Border>

                <!-- Supplier Bulk Selection -->
                <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" Margin="5,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Bulk Supplier Assignment" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" 
                                      ItemsSource="{Binding Suppliers}" 
                                      SelectedItem="{Binding SelectedBulkSupplier}"
                                      DisplayMemberPath="Name"/>
                            <Button Grid.Column="1" Content="+" Command="{Binding AddNewSupplierCommand}" Width="30" Margin="5,0,0,0"/>
                        </Grid>

                        <Button Grid.Row="2" Content="Apply to All Items" Command="{Binding ApplyBulkSupplierCommand}"/>
                    </Grid>
                </Border>

                <!-- Invoice Bulk Selection -->
                <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,0" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Bulk Invoice Assignment" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" 
                                      ItemsSource="{Binding SupplierInvoices}" 
                                      SelectedItem="{Binding SelectedBulkInvoice}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding InvoiceNumber}"/>
                                            <Run Text=" - "/>
                                            <Run Text="{Binding SupplierName}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="1" Content="+" Command="{Binding AddNewInvoiceCommand}" Width="30" Margin="5,0,0,0"/>
                        </Grid>

                        <Button Grid.Row="2" Content="Apply to All Items" Command="{Binding ApplyBulkInvoiceCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Expander>

        <!-- Import Options -->
        <Grid Grid.Row="2" Margin="0,5,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Import Options" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <TabControl Grid.Row="1">
                <TabItem Header="Manual Entry">
                    <StackPanel Margin="0,10">
                        <TextBlock Text="Add items manually to the grid below." Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Add Row" Command="{Binding AddRowCommand}" Width="120" Margin="0,0,10,0"/>
                            <Button Content="Generate Barcodes" Command="{Binding GenerateAllBarcodesCommand}" Width="150" Margin="0,0,10,0"/>
                            <CheckBox Content="Auto-generate barcodes for new items" 
                                      IsChecked="{Binding GenerateBarcodesForNewItems}" 
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Print Barcodes" Command="{Binding PrintAllBarcodesCommand}" Width="120" Margin="0,0,10,0"/>
                            <TextBlock Text="Labels per item:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Text="{Binding LabelsPerItem}" Width="50" Margin="0,0,10,0"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
                <TabItem Header="CSV Import">
                    <Grid Margin="0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Paste CSV content below or use the template." Margin="0,0,0,10"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding CsvContent, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="150"/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Parse CSV" Command="{Binding ParseCsvCommand}" Width="120" Margin="0,0,10,0"/>
                            <Button Content="Download Template" Command="{Binding DownloadTemplateCommand}" Width="150"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Items Grid -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Items to Add" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <!-- Remove Button -->
                    <DataGridTemplateColumn Width="40" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="×" 
                                        Command="{Binding DataContext.RemoveRowCommand, 
                                                 RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Width="25" Height="25"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Name -->
                    <DataGridTextColumn Header="Name *" 
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="*"/>

                    <!-- Barcode -->
                    <DataGridTextColumn Header="Barcode" 
                                        Binding="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="130"/>

                    <!-- Category -->
                    <DataGridTemplateColumn Header="Category *" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Categories, 
                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="CategoryId"
                                          SelectedValue="{Binding CategoryId, UpdateSourceTrigger=PropertyChanged}"
                                          Width="110"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Supplier -->
                    <DataGridTemplateColumn Header="Supplier" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Suppliers, 
                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="SupplierId"
                                          SelectedValue="{Binding SupplierId, UpdateSourceTrigger=PropertyChanged}"
                                          Width="110"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Purchase Price -->
                    <DataGridTextColumn Header="Purchase Price" 
                                        Binding="{Binding PurchasePrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="100"/>

                    <!-- Sale Price -->
                    <DataGridTextColumn Header="Sale Price *" 
                                        Binding="{Binding SalePrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="100"/>

                    <!-- Stock -->
                    <DataGridTextColumn Header="Stock" 
                                        Binding="{Binding CurrentStock, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="70"/>

                    <!-- Min Stock -->
                    <DataGridTextColumn Header="Min Stock" 
                                        Binding="{Binding MinimumStock, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="70"/>

                    <!-- Image Management -->
                    <DataGridTemplateColumn Header="Image" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel Orientation="Horizontal" 
                                                Visibility="{Binding ImagePath, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=inverse}">
                                        <Button Content="Upload" 
                                                Command="{Binding DataContext.UploadItemImageCommand, 
                                                         RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Width="80"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" 
                                                Visibility="{Binding ImagePath, Converter={StaticResource StringToVisibilityConverter}}">
                                        <Image Source="{Binding ImagePath, Converter={StaticResource FilePathToImageConverter}, ConverterParameter=40}" 
                                               Width="40" Height="40" Margin="0,0,5,0"/>
                                        <Button Content="Clear" 
                                                Command="{Binding DataContext.ClearItemImageCommand, 
                                                         RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Width="50"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Barcode Image -->
                    <DataGridTemplateColumn Header="Barcode" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding BarcodeImage, Converter={StaticResource ByteArrayToImageConverter}}" 
                                       Stretch="Uniform" 
                                       Height="40" 
                                       Width="100" 
                                       Margin="5"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Active Status -->
                    <DataGridCheckBoxColumn Header="Active" 
                                           Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" 
                                           Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Footer with Status and Buttons -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status Message -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
                <ProgressBar Width="200" Height="15" Margin="10,0,0,0" 
                             Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Minimum="0" Maximum="{Binding TotalRows}" Value="{Binding CurrentRow}"
                             IsIndeterminate="{Binding TotalRows, Converter={StaticResource IntZeroToBoolConverter}}"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Clear All" Command="{Binding ClearAllCommand}" Width="100" Margin="0,0,10,0"/>
                <Button Content="Cancel" Click="CancelButton_Click" Width="100" Margin="0,0,10,0"/>
                <Button Content="Save All" Command="{Binding SaveAllCommand}" Width="100"/>
            </StackPanel>
        </Grid>

        <!-- Overlay when saving -->
        <Border Grid.Row="0" Grid.RowSpan="5" 
                Background="#80000000" 
                Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="White" 
                           FontSize="16" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <ProgressBar Width="300" 
                             Height="20" 
                             Minimum="0" 
                             Maximum="{Binding TotalRows}" 
                             Value="{Binding CurrentRow}"
                             IsIndeterminate="{Binding TotalRows, Converter={StaticResource IntZeroToBoolConverter}}"/>
                <TextBlock Foreground="White"
           HorizontalAlignment="Center"
           Margin="0,10,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Processing item {0} of {1}">
                            <Binding Path="CurrentRow"/>
                            <Binding Path="TotalRows"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>