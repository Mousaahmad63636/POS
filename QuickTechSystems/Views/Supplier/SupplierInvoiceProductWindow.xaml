<!-- File: QuickTechSystems\Views\Supplier\SupplierInvoiceProductWindow.xaml -->
<Window x:Class="QuickTechSystems.WPF.Views.SupplierInvoiceProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invoice Product Management"
        Height="800" Width="1400"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        KeyDown="Window_KeyDown"
        Background="#F8F9FA">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Add the converter for calculating invoice totals -->
        <local:InvoiceDetailsTotalConverter x:Key="InvoiceDetailsTotalConverter" xmlns:local="clr-namespace:QuickTechSystems.WPF.Converters"/>

        <!-- Add the converter for product ID to visibility -->
        <local:ProductIdToVisibilityConverter x:Key="ProductIdToVisibilityConverter" xmlns:local="clr-namespace:QuickTechSystems.WPF.Converters"/>

        <!-- Modern Card Style -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004578"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success Button Style -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#28A745"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#218838"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E7E34"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Icon Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" 
                                            Padding="{TemplateBinding Padding}"
                                            VerticalAlignment="Center"/>
                                <TextBlock x:Name="PlaceholderText"
                                         Text="{TemplateBinding Tag}"
                                         Foreground="#6C757D"
                                         Padding="{TemplateBinding Padding}"
                                         VerticalAlignment="Center"
                                         IsHitTestVisible="False"
                                         Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Results Style -->
        <Style x:Key="SearchResultsListBox" TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="MaxHeight" Value="200"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,0,8,8">
                            <ScrollViewer x:Name="PART_ScrollViewer" 
                                        Padding="{TemplateBinding Padding}"
                                        VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search Result Item Style -->
        <Style x:Key="SearchResultItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderThickness="0,0,0,1" BorderBrush="#E9ECEF">
            <Grid Margin="32,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📦 Invoice Product Management" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#212529"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="• Invoice: " 
                                   FontSize="14" 
                                   Foreground="#6C757D"/>
                        <TextBlock Text="{Binding Invoice.InvoiceNumber, FallbackValue='Loading...'}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="#007ACC"/>
                        <TextBlock Text=" • Supplier: " 
                                   FontSize="14" 
                                   Foreground="#6C757D" 
                                   Margin="12,0,0,0"/>
                        <TextBlock Text="{Binding Invoice.SupplierName, FallbackValue='Loading...'}" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="#007ACC"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" 
                        Click="CloseButton_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Close Window">
                    <TextBlock Text="✕" FontSize="16" Foreground="#6C757D"/>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="32">
            <StackPanel>

                <!-- Quick Add Section -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header Section -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#E3F2FD" 
                                    CornerRadius="50" 
                                    Width="40" 
                                    Height="40" 
                                    Margin="0,0,16,0">
                                <TextBlock Text="⚡" 
                                           FontSize="18" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Quick Add Product" 
                                           FontSize="16" 
                                           FontWeight="SemiBold" 
                                           Foreground="#212529"/>
                                <TextBlock Text="Scan barcode, search by name, or create new product" 
                                           FontSize="12" 
                                           Foreground="#6C757D"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2" Grid.Row="0" 
                                Content="➕ Create New Product"
                                Command="{Binding OpenNewProductDialogCommand}"
                                Style="{StaticResource SuccessButton}"
                                MinWidth="180"/>

                        <!-- Search Options Section -->
                        <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Barcode Search -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🔍 Scan or Enter Barcode" 
                                           FontWeight="SemiBold" 
                                           FontSize="14" 
                                           Margin="0,0,0,8" 
                                           Foreground="#495057"/>
                                <TextBox x:Name="QuickBarcodeTextBox"
                                         Text="{Binding NewProductRow.ProductBarcode, UpdateSourceTrigger=PropertyChanged}"
                                         LostFocus="BarcodeTextBox_LostFocus"
                                         KeyDown="QuickBarcodeTextBox_KeyDown"
                                         Style="{StaticResource ModernTextBox}"
                                         Tag="Enter or scan product barcode..."/>
                            </StackPanel>

                            <!-- OR Separator -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Border Background="#E9ECEF" 
                                        CornerRadius="12" 
                                        Padding="12,6">
                                    <TextBlock Text="OR" 
                                               FontWeight="SemiBold" 
                                               FontSize="12"
                                               Foreground="#6C757D"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- Product Name Search -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="📝 Search by Product Name" 
                                           FontWeight="SemiBold" 
                                           FontSize="14" 
                                           Margin="0,0,0,8" 
                                           Foreground="#495057"/>
                                <Grid>
                                    <TextBox x:Name="ProductNameSearchTextBox"
                                             Text="{Binding ProductNameSearch, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="ProductNameSearchTextBox_KeyDown"
                                             Style="{StaticResource ModernTextBox}"
                                             Tag="Type product name to search..."/>

                                    <!-- Search Results Popup -->
                                    <Popup IsOpen="{Binding ShowSearchResults}" 
                                           PlacementTarget="{Binding ElementName=ProductNameSearchTextBox}"
                                           Placement="Bottom"
                                           AllowsTransparency="True"
                                           StaysOpen="False">
                                        <!-- FIXED: Replaced problematic Effect binding with proper DropShadowEffect -->
                                        <Border Background="White"
                                                BorderBrush="#E9ECEF"
                                                BorderThickness="1"
                                                CornerRadius="0,0,8,8">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Color="#000000"/>
                                            </Border.Effect>
                                            <ListBox ItemsSource="{Binding SearchResults}"
                                                     SelectedItem="{Binding SelectedSearchResult}"
                                                     Style="{StaticResource SearchResultsListBox}"
                                                     Width="{Binding ActualWidth, ElementName=ProductNameSearchTextBox}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource IconButton}"
                                                                Command="{Binding DataContext.SelectSearchResultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Left">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="{Binding Name}" 
                                                                               FontWeight="SemiBold" 
                                                                               FontSize="13"/>
                                                                    <TextBlock Text="{Binding Barcode, StringFormat='Barcode: {0}'}" 
                                                                               FontSize="11" 
                                                                               Foreground="#6C757D"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                                    <TextBlock Text="{Binding PurchasePrice, StringFormat='${0:N2}'}" 
                                                                               FontWeight="SemiBold" 
                                                                               FontSize="12" 
                                                                               Foreground="#28A745"/>
                                                                    <TextBlock Text="{Binding CurrentStock, StringFormat='Stock: {0}'}" 
                                                                               FontSize="11" 
                                                                               Foreground="#6C757D"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Margin" Value="0"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Product Details Section (when product is selected) -->
                <Border Style="{StaticResource ModernCard}" 
                        Margin="0,0,0,24"
                        Visibility="{Binding NewProductRow.ProductId, Converter={StaticResource ProductIdToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Product Info -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📦 Product" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding NewProductRow.ProductName}" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding NewProductRow.ProductBarcode, StringFormat='Barcode: {0}'}" 
                                       FontSize="12" 
                                       Foreground="#6C757D"/>
                        </StackPanel>

                        <!-- Quantity -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="📊 Quantity *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewProductRow.Quantity, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Enter quantity..."/>
                        </StackPanel>

                        <!-- Purchase Price -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="💰 Purchase Price *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewProductRow.PurchasePrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Enter purchase price..."
                                     LostFocus="CalculationTextBox_LostFocus"/>
                        </StackPanel>

                        <!-- Add Button -->
                        <Button Grid.Column="6" 
                                Content="➕ Add to Invoice"
                                Command="{Binding AddRowCommand}"
                                Style="{StaticResource SuccessButton}"
                                MinWidth="140"
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <!-- Products List Section -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📋 Invoice Products" 
                                           FontSize="18" 
                                           FontWeight="SemiBold" 
                                           Foreground="#212529"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border Background="#E3F2FD" 
                                            CornerRadius="12" 
                                            Padding="8,4">
                                        <TextBlock Text="{Binding InvoiceDetails.Count, StringFormat='Products'}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="#007ACC"/>
                                    </Border>
                                    <Border Background="#FFF3CD" 
                                            CornerRadius="12" 
                                            Padding="8,4" 
                                            Margin="8,0,0,0">
                                        <TextBlock Text="{Binding InvoiceDetails, Converter={StaticResource InvoiceDetailsTotalConverter}, StringFormat='Total: ${0:N2}'}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="#856404"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="💾 Save Changes"
                                        Command="{Binding SaveChangesCommand}"
                                        Style="{StaticResource SuccessButton}"
                                        Margin="0,0,12,0"
                                        MinWidth="140"/>
                                <Button Content="🔄 Refresh"
                                        Command="{Binding LoadDataCommand}"
                                        Style="{StaticResource ModernButton}"
                                        MinWidth="100"/>
                            </StackPanel>
                        </Grid>

                        <!-- Products DataGrid -->
                        <DataGrid ItemsSource="{Binding InvoiceDetails}"
                                  SelectedItem="{Binding SelectedDetail}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  Background="White"
                                  BorderThickness="1"
                                  BorderBrush="#E9ECEF"
                                  RowHeight="50">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="BorderBrush" Value="#E9ECEF"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F8F9FA"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product Name" 
                                                    Binding="{Binding ProductName}" 
                                                    Width="250"
                                                    IsReadOnly="True"/>

                                <DataGridTextColumn Header="Barcode" 
                                                    Binding="{Binding ProductBarcode}" 
                                                    Width="120"
                                                    IsReadOnly="True"/>

                                <DataGridTextColumn Header="Quantity" 
                                                    Binding="{Binding Quantity, StringFormat=N2}" 
                                                    Width="100"
                                                    IsReadOnly="True"/>

                                <DataGridTextColumn Header="Purchase Price" 
                                                    Binding="{Binding PurchasePrice, StringFormat=C}" 
                                                    Width="120"
                                                    IsReadOnly="True"/>

                                <DataGridTextColumn Header="Total Price" 
                                                    Binding="{Binding TotalPrice, StringFormat=C}" 
                                                    Width="120"
                                                    IsReadOnly="True"/>

                                <DataGridTextColumn Header="Current Stock" 
                                                    Binding="{Binding CurrentStock, StringFormat=N0}" 
                                                    Width="100"
                                                    IsReadOnly="True"/>

                                <DataGridTemplateColumn Header="Actions" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️ Remove"
                                                    Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IconButton}"
                                                    Foreground="#DC3545"
                                                    FontSize="12"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2" 
              Background="#80000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" 
                    CornerRadius="12" 
                    Padding="40,30" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="24" Margin="0,0,16,0"/>
                    <TextBlock Text="Loading..." 
                               FontSize="16" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- New Product Dialog Modal -->
        <Grid Grid.Row="0" Grid.RowSpan="2" 
              Background="#80000000" 
              Visibility="{Binding IsNewProductDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!-- Modal content would go here - keeping existing modal implementation -->
        </Grid>
    </Grid>
</Window>