<UserControl x:Class="QuickTechSystems.WPF.Views.TransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Loaded="TransactionView_Loaded"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header (Formerly HeaderPanel.xaml) -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Barcode Search -->
                <Grid Grid.Column="1">
                    <TextBox x:Name="BarcodeTextBox"
                             Text="{Binding BarcodeText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ProcessBarcodeCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="Scan barcode..."
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=BarcodeTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFocused, ElementName=BarcodeTextBox}" Value="True">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Restaurant Table Information -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🍽️" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TableHeaderText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Change Table" Command="{Binding SwitchTableCommand}"/>
                </StackPanel>

                <!-- Product Search -->
                <Grid Grid.Column="3" 
                      Visibility="{Binding IsRestaurantMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TextBox x:Name="ProductSearchTextBox"
                             Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Search products by name..."
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=ProductSearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFocused, ElementName=ProductSearchTextBox}" Value="True">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Customer Search -->
                <Grid Grid.Column="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="CustomerSearchContainer" Grid.Column="0">
                        <TextBox x:Name="CustomerSearchBox"
                                 Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="CustomerSearchPlaceholder"
                                   Text="Search customer..."
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=CustomerSearchBox}" Value=""/>
                                                <Condition Binding="{Binding SelectedCustomer}" Value="{x:Null}"/>
                                                <Condition Binding="{Binding IsFocused, ElementName=CustomerSearchBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Loading indicator -->
                        <ProgressBar Height="2" 
                                     IsIndeterminate="True" 
                                     Visibility="{Binding IsSearching, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     VerticalAlignment="Bottom"/>

                        <!-- Search message popup -->
                        <Popup IsOpen="{Binding IsSearchMessageVisible}"
                               PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Width="{Binding ActualWidth, ElementName=CustomerSearchBox}">
                            <Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="⚠️" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SearchMessage}" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </Popup>

                        <!-- Customer search popup -->
                        <Popup IsOpen="{Binding IsCustomerSearchVisible}"
                               PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               Width="{Binding ActualWidth, ElementName=CustomerSearchBox}">
                            <Border>
                                <ListView x:Name="CustomerSearchList" 
                                         ItemsSource="{Binding FilteredCustomers}"
                                         SelectedItem="{Binding SelectedCustomerFromSearch}"
                                         MaxHeight="300"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         BorderThickness="0">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,4">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name, FallbackValue='Unknown'}"/>
                                                    <TextBlock Text="{Binding Phone, FallbackValue='No phone'}" FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Clear Customer Button -->
                    <Button Grid.Column="1"
                            Content="✕"
                            Click="CustomerCancelButton_Click"
                            Margin="5,0,0,0"/>
                </Grid>

                <!-- New Customer Button -->
                <Button Grid.Column="5"
                        Content="New Customer"
                        Command="{Binding NewCustomerCommand}"
                        Margin="10,0,10,0"/>

                <!-- Transaction Lookup -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="120" Height="35">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="LookupTransactionIdTextBox"
                                 Text="{Binding LookupTransactionId, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding LookupTransactionCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <StackPanel Grid.Column="1" Orientation="Vertical" Width="24">
                            <Button Command="{Binding IncrementTransactionIdCommand}" Height="17">
                                <TextBlock Text="▲" FontSize="8"/>
                            </Button>
                            <Button Command="{Binding DecrementTransactionIdCommand}" Height="18">
                                <TextBlock Text="▼" FontSize="8"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Button Content="Lookup" Command="{Binding LookupTransactionCommand}" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Categories and Totals -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Category Tabs - Restaurant Mode Only -->
                <Border Grid.Column="0" 
                        Padding="5,5,5,2"
                        Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ProductCategories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Name}"
                                            Command="{Binding DataContext.SelectCategoryCommand, 
                                                     RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="3,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Totals Summary -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Items Count -->
                    <TextBlock Text="Items:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding ItemCount}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <!-- Subtotal -->
                    <TextBlock Text="Subtotal:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding SubTotal, StringFormat=C2}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <!-- Discount -->
                    <TextBlock Text="Discount:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding DiscountAmount, StringFormat=C2}" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <!-- Total -->
                    <TextBlock Text="Total:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat=C2}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="/" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding TotalAmountLBP}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBlock Text=" LBP" VerticalAlignment="Center" Margin="0,0,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Main Content Area -->
        <Border Grid.Row="1" Margin="20">
            <!-- Content Area with dynamic split -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side: Transaction Grid or Product Cards -->
                <Grid Grid.Column="0">
                    <!-- Transaction Grid -->
                    <Grid Visibility="{Binding IsProductCardsVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <DataGrid Margin="0,20,0,20"
                                 SelectionChanged="DataGrid_SelectionChanged"
                                 ItemsSource="{Binding CurrentTransaction.Details, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" 
                                                  Binding="{Binding ProductBarcode, FallbackValue=''}"
                                                  Width="120"/>
                                <DataGridTextColumn Header="Description" 
                                                  Binding="{Binding ProductName, FallbackValue='Unknown Product'}"
                                                  Width="*"/>

                                <!-- Quantity Column -->
                                <DataGridTemplateColumn Header="Quantity" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                     TextAlignment="Center"
                                                     Padding="8,0"
                                                     PreviewTextInput="Quantity_PreviewTextInput"
                                                     LostFocus="Quantity_LostFocus"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Unit Price" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding UnitPrice, StringFormat={}{0:C2}}"
                                                    Click="PriceButton_Click"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    HorizontalAlignment="Right"
                                                    Padding="8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Total" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Total, StringFormat={}{0:C2}}"
                                                       TextAlignment="Right"
                                                       Padding="8,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="×"
                                                    Command="{Binding DataContext.RemoveItemCommand, 
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="20"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Product Cards Panel -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsProductCardsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8"
                                            Width="150"
                                            Height="180"
                                            MouseLeftButtonDown="Product_MouseLeftButtonDown"
                                            Cursor="Hand">
                                        <Grid>
                                            <!-- Product Info -->
                                            <StackPanel VerticalAlignment="Bottom" Margin="12,0,12,12">
                                                <TextBlock Text="{Binding Name}"
                                                         FontSize="13"
                                                         TextWrapping="Wrap"
                                                         MaxHeight="36"
                                                         TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Text="{Binding SalePrice, StringFormat='{}{0:C}'}"
                                                         FontSize="14"
                                                         Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Right Side: Product Summary Table (Only in Restaurant Mode) -->
                <GridSplitter Grid.Column="1" 
                              Width="5" 
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Center"
                              Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Grid Grid.Column="2" 
                      Width="400"
                      Visibility="{Binding IsRestaurantMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Current Order" FontSize="16" Margin="0,0,0,10"/>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding CurrentTransaction.Details}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      SelectionChanged="DataGrid_SelectionChanged"
                                      RowHeight="30"
                                      MaxHeight="600">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" 
                                                       Binding="{Binding ProductName, FallbackValue='[No name]'}" 
                                                       Width="*"/>
                                    <DataGridTextColumn Header="Qty" 
                                                       Binding="{Binding Quantity, FallbackValue=0}" 
                                                       Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="5,5"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <EventSetter Event="MouseLeftButtonDown" Handler="Quantity_MouseLeftButtonDown"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="Price" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding UnitPrice, StringFormat={}{0:C2}}"
                                                        Click="PriceButton_Click"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        HorizontalAlignment="Right"
                                                        Padding="5,5"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Total" 
                                                       Binding="{Binding Total, StringFormat=C2, FallbackValue=$0.00}" 
                                                       Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="5,5"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Width="40">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕"
                                                        Command="{Binding DataContext.RemoveItemCommand, 
                                                                 RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="16"
                                                        Padding="5,0"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Function Buttons -->
        <UniformGrid x:Name="functionButtonsGrid" 
                     Grid.Row="2" 
                     Rows="1" 
                     Columns="10"
                     Margin="20,0,20,10">
            <Button Content="Void Last Item (F2)"
                    Command="{Binding VoidLastItemCommand}"
                    Margin="4"/>
            <Button Content="Change Quantity (F3)" 
                    Command="{Binding ChangeQuantityCommand}"
                    Margin="4"/>
            <Button Content="Save as Quote"
                    Command="{Binding SaveAsQuoteCommand}"
                    Margin="4"/>
            <Button Content="Price Check (F4)"
                    Command="{Binding PriceCheckCommand}"
                    Margin="4"/>
            <Button Content="Add Discount (F5)"
                    Command="{Binding AddDiscountCommand}"
                    Margin="4"/>
            <Button Content="Close Drawer"
                    Command="{Binding CloseDrawerCommand}"
                    Margin="4"/>
            <Button Content="{Binding CashPaymentButtonText}"
                    Command="{Binding CashPaymentCommand}"
                    Margin="4"/>
            <Button Content="{Binding CustomerBalanceButtonText}"
                    Command="{Binding AddToCustomerBalanceCommand}"
                    Margin="4"/>
            <Button Content="Clear All (F10)"
                    Command="{Binding ClearTransactionCommand}"
                    Margin="4"/>
            <Button Content="New Transaction"
                    Command="{Binding NewTransactionWindowCommand}"
                    Margin="4"/>
        </UniformGrid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ConnectionStatus}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Product Search Popup -->
        <Popup IsOpen="{Binding IsProductSearchVisible}"
               StaysOpen="False"
               AllowsTransparency="True"
               Width="800"
               MaxHeight="400"
               Placement="Center">
            <Border>
                <DataGrid ItemsSource="{Binding FilteredProducts}"
                         MouseDoubleClick="ProductSearchGrid_MouseDoubleClick"
                         KeyDown="ProductSearchGrid_KeyDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" 
                                          Binding="{Binding Barcode}"
                                          Width="120"/>
                        <DataGridTextColumn Header="Description" 
                                          Binding="{Binding Name}"
                                          Width="*"/>
                        <DataGridTextColumn Header="Category" 
                                          Binding="{Binding CategoryName}"
                                          Width="120"/>
                        <DataGridTextColumn Header="Unit Price" 
                                          Binding="{Binding SalePrice, StringFormat=C2}"
                                          Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Popup>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay"
              Background="#80000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              Grid.RowSpan="4"
              Panel.ZIndex="1000">
            <Border Width="300" Height="100">
                <StackPanel HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Margin="20">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="200" 
                                 Height="2" 
                                 Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding LoadingMessage}" 
                               HorizontalAlignment="Center"
                               FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>