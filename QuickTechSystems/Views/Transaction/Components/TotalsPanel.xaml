<UserControl x:Class="QuickTechSystems.WPF.Views.Transaction.Components.TotalsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Combined Items Count and Discount Row -->
        <Grid Grid.Row="0" Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Items Count -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource Transaction_Items}"
                           FontSize="14"
                           Foreground="#4B5563"/>
                <TextBlock Text="{Binding ItemCount}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="4,0,0,0"/>
            </StackPanel>
            <!-- Discount -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{DynamicResource Transaction_Discount}"
                           FontSize="14"
                           Foreground="#EF4444"/>
                <TextBlock Text="{Binding DiscountAmount, StringFormat=N}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#EF4444"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Subtotal -->
        <Grid Grid.Row="1" Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

        </Grid>

        <!-- Total -->
        <Border Grid.Row="2"
                Background="#1E293B"
                CornerRadius="8"
                Padding="6"
                Margin="0,4">
            <StackPanel>
                <TextBlock Text="{DynamicResource Transaction_Total}"
                           Foreground="#94A3B8"
                           FontSize="12"/>
                <TextBlock Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Text="{Binding TotalAmount, StringFormat=N}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
