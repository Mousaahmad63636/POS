<UserControl x:Class="QuickTechSystems.WPF.Views.Transaction.Components.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MaxWidth="60" MaxHeight="60" Width="60" Height="60">

    <!-- Border Style -->
    <Border Background="White" 
            BorderBrush="#E5E7EB" 
            BorderThickness="1" 
            CornerRadius="8" 
            Margin="5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Direction="270" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <!-- Product Image with Overlay -->
            <Grid>
                <!-- Background Image -->
                <Border Background="#F9FAFB" 
                        CornerRadius="8">
                    <Image Source="{Binding Image, Converter={StaticResource ByteArrayToImageConverter}}"
                           Stretch="UniformToFill"
                           MaxHeight="180"/>
                </Border>
                <!-- Semi-transparent Gradient Overlay -->
                <Border Height="70"
                        VerticalAlignment="Bottom"
                        CornerRadius="0,0,8,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#CC000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- Product Info Overlay -->
                <StackPanel VerticalAlignment="Bottom"
                          Margin="8,0,8,8">
                    <TextBlock Text="{Binding Name}"
                             Foreground="White"
                             FontWeight="SemiBold"
                             FontSize="11"
                             TextWrapping="Wrap"
                             MaxHeight="30"
                             TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding SalePrice, StringFormat='{}{0:C}'}"
                             Foreground="White"
                             FontSize="13"
                             FontWeight="Bold"
                             Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>