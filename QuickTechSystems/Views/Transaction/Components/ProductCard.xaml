<UserControl x:Class="QuickTechSystems.WPF.Views.Transaction.Components.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:QuickTechSystems.WPF.Converters">

    <UserControl.Resources>
        <converters:UsdToLbpConverter x:Key="UsdToLbpConverter"/>

        <!-- Restaurant Mode Style -->
        <Style x:Key="RestaurantCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Normal Mode Style -->
        <Style x:Key="NormalCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="180"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10"
                                    ShadowDepth="3"
                                    Direction="270"
                                    Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border>
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource NormalCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="4"/>
                        <Setter Property="Margin" Value="2"/>
                        <Setter Property="Width" Value="38"/>
                        <Setter Property="Height" Value="45"/>
                        <Setter Property="Effect" Value="{x:Null}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- Background Image -->
            <Border Background="#F9FAFB">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                                <Setter Property="CornerRadius" Value="4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Image Source="{Binding ImagePath, Converter={StaticResource FilePathToImageConverter}, ConverterParameter=150}" 
                       Stretch="UniformToFill">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Height" Value="180"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                                    <Setter Property="Height" Value="45"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
            </Border>

            <!-- Semi-transparent Gradient Overlay - Only in normal mode -->
            <Border VerticalAlignment="Bottom">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Height" Value="90"/>
                        <Setter Property="CornerRadius" Value="0,0,8,8"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#CC000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Product Info Overlay -->
            <StackPanel VerticalAlignment="Bottom">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Margin" Value="12,0,12,12"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                                <Setter Property="Margin" Value="2,0,2,2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="{Binding Name}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap"
                         TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="MaxHeight" Value="36"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontSize" Value="8"/>
                                    <Setter Property="MaxHeight" Value="16"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="{Binding SalePrice, StringFormat='{}{0:C}'}"
                         FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Margin" Value="0,4,0,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontSize" Value="7"/>
                                    <Setter Property="Margin" Value="0,1,0,0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="{Binding SalePrice, Converter={StaticResource UsdToLbpConverter}}"
                         FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#E0E0E0"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Margin" Value="0,0,0,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsRestaurantMode, RelativeSource={RelativeSource AncestorType=UserControl, AncestorLevel=2}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>