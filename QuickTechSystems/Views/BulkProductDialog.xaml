<Window x:Class="QuickTechSystems.WPF.Views.BulkProductDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Add Products" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <CollectionViewSource x:Key="CategoriesViewSource" 
                            Source="{Binding Categories}"/>
        <CollectionViewSource x:Key="SuppliersViewSource" 
                            Source="{Binding Suppliers}"/>

        <!-- Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0056b3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel>
            <TextBlock Text="Bulk Add Products"
                     FontSize="24"
                     FontWeight="Bold"
                     Margin="0,0,0,10"/>
            <TextBlock Text="Add multiple products at once"
                     Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                     Margin="0,0,0,20"/>
        </StackPanel>

        <!-- Quick Actions Bar -->
        <StackPanel Grid.Row="1" 
                   Orientation="Horizontal" 
                   Margin="0,0,0,10">
            <Button Content="Add 5 Rows"
                    Command="{Binding AddFiveRowsCommand}"
                    Style="{StaticResource ActionButton}"
                    Width="100"
                    Margin="0,0,10,0"/>
            <Button Content="Add 10 Rows"
                    Command="{Binding AddTenRowsCommand}"
                    Style="{StaticResource ActionButton}"
                    Width="100"
                    Margin="0,0,10,0"/>
            <Button Content="Clear Empty Rows"
                    Command="{Binding ClearEmptyRowsCommand}"
                    Style="{StaticResource ActionButton}"
                    Width="120"
                    Margin="0,0,10,0"/>
            <Button Content="Clear All"
                    Command="{Binding ClearAllCommand}"
                    Style="{StaticResource ActionButton}"
                    Width="80"/>

            <Separator Width="1" 
                      Background="#E0E0E0" 
                      Margin="15,0"/>

            <!-- Quick Fill Options -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Quick Fill:" 
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"/>
                <ComboBox Width="150" 
                         Height="30"
                         Margin="0,0,10,0"
                         SelectedValue="{Binding SelectedQuickFillOption}">
                    <ComboBoxItem Content="Category"/>
                    <ComboBoxItem Content="Supplier"/>
                    <ComboBoxItem Content="Purchase Price"/>
                    <ComboBoxItem Content="Sale Price"/>
                    <ComboBoxItem Content="Stock Values"/>
                    <ComboBoxItem Content="Speed"/>
                </ComboBox>
                <TextBox Width="100"
                         Height="30"
                         Margin="0,0,10,0"
                         Text="{Binding QuickFillValue, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Apply to Selected"
                        Command="{Binding ApplyQuickFillCommand}"
                        Style="{StaticResource ActionButton}"
                        Width="120"/>
            </StackPanel>
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="2" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1" 
                Margin="0,0,0,20">
            <DataGrid ItemsSource="{Binding Products}"
                     AutoGenerateColumns="False"
                     CanUserAddRows="True"
                     SelectionMode="Extended"
                     SelectionUnit="FullRow"
                     GridLinesVisibility="All"
                     AlternatingRowBackground="#F5F5F5">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Select" 
                                          Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          Width="60"/>
                    <DataGridTemplateColumn Header="Barcode Tools" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Generate Barcode"
                                        Command="{Binding DataContext.GenerateBarcodeCommand, 
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource ActionButton}"
                                        Padding="5,2"
                                        Height="25"
                                        Margin="2"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Barcode" 
                                      Binding="{Binding Barcode}"
                                      Width="120"/>
                    <DataGridTextColumn Header="Name" 
                                      Binding="{Binding Name}"
                                      Width="*"/>
                    <DataGridComboBoxColumn Header="Category"
                                          ItemsSource="{Binding Source={StaticResource CategoriesViewSource}}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="CategoryId"
                                          SelectedValueBinding="{Binding CategoryId}"
                                          Width="150"/>
                    <DataGridComboBoxColumn Header="Supplier"
                                          ItemsSource="{Binding Source={StaticResource SuppliersViewSource}}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="SupplierId"
                                          SelectedValueBinding="{Binding SupplierId}"
                                          Width="150"/>
                    <DataGridTextColumn Header="Purchase Price" 
                                      Binding="{Binding PurchasePrice}"
                                      Width="120"/>
                    <DataGridTextColumn Header="Sale Price" 
                                      Binding="{Binding SalePrice}"
                                      Width="120"/>
                    <DataGridTextColumn Header="Current Stock" 
                                      Binding="{Binding CurrentStock}"
                                      Width="100"/>
                    <DataGridTextColumn Header="Minimum Stock" 
                                      Binding="{Binding MinimumStock}"
                                      Width="100"/>
                    <DataGridTextColumn Header="Speed" 
                                      Binding="{Binding Speed}"
                                      Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status Bar -->
        <DockPanel Grid.Row="3" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" 
                      Text="Total Items: "
                      VerticalAlignment="Center"/>
            <TextBlock DockPanel.Dock="Left" 
                      Text="{Binding Products.Count}"
                      FontWeight="Bold"
                      Margin="5,0,0,0"
                      VerticalAlignment="Center"/>

            <!-- Action Buttons -->
            <StackPanel DockPanel.Dock="Right" 
                       Orientation="Horizontal">
                <Button Content="Import from Excel"
                        Command="{Binding ImportFromExcelCommand}"
                        Style="{StaticResource ActionButton}"
                        Height="35"
                        Width="120"
                        Margin="0,0,10,0"/>
                <Button Content="Save All"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionButton}"
                        Height="35"
                        Width="120"
                        Background="#28A745"
                        Margin="0,0,10,0"/>
                <Button Content="Cancel"
                        IsCancel="True"
                        Height="35"
                        Width="80"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>