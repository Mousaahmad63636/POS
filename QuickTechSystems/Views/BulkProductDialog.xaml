<Window x:Class="QuickTechSystems.WPF.Views.BulkProductDialog"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="{DynamicResource Product_BulkAdd}" 
       Height="600" 
       Width="1200"
       WindowStartupLocation="CenterOwner"
       Background="White">

    <Window.Resources>
        <CollectionViewSource x:Key="PlantsHardscapeCategoriesViewSource" 
                           Source="{Binding PlantsHardscapeCategories}"/>
        <CollectionViewSource x:Key="LocalImportedCategoriesViewSource" 
                           Source="{Binding LocalImportedCategories}"/>
        <CollectionViewSource x:Key="IndoorOutdoorCategoriesViewSource" 
                           Source="{Binding IndoorOutdoorCategories}"/>
        <CollectionViewSource x:Key="PlantFamilyCategoriesViewSource" 
                           Source="{Binding PlantFamilyCategories}"/>
        <CollectionViewSource x:Key="DetailCategoriesViewSource" 
                           Source="{Binding DetailCategories}"/>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="{TemplateBinding BorderThickness}"
                               CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0056b3"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                           Value="{Binding RelativeSource={RelativeSource Self},
                                  Path=(Validation.Errors)[0].ErrorContent}"/>
                    <Setter Property="Background" Value="#FFF0F0"/>
                    <Setter Property="BorderBrush" Value="#FFE0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{DynamicResource Product_BulkAdd}"
                    FontSize="24"
                    FontWeight="Bold"
                    Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource Product_BulkAddSubtitle}"
                    Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                    Margin="0,0,0,20"/>
        </StackPanel>

        <StackPanel Grid.Row="1" 
                  Orientation="Horizontal" 
                  Margin="0,0,0,10">
            <Button Content="{DynamicResource Product_BulkAdd_AddOneRow}"
                   Command="{Binding AddOneRowCommand}"
                   Style="{StaticResource ActionButton}"
                   Width="100"
                   Margin="0,0,10,0"/>
            <Button Content="{DynamicResource Product_BulkAdd_AddFiveRows}"
                   Command="{Binding AddFiveRowsCommand}"
                   Style="{StaticResource ActionButton}"
                   Width="100"
                   Margin="0,0,10,0"/>
            <Button Content="{DynamicResource Product_BulkAdd_AddTenRows}"
                   Command="{Binding AddTenRowsCommand}"
                   Style="{StaticResource ActionButton}"
                   Width="100"
                   Margin="0,0,10,0"/>
            <Button Content="{DynamicResource Product_BulkAdd_ClearEmptyRows}"
                   Command="{Binding ClearEmptyRowsCommand}"
                   Style="{StaticResource ActionButton}"
                   Width="120"
                   Margin="0,0,10,0"/>
            <Button Content="{DynamicResource Expense_Clear}"
                   Command="{Binding ClearAllCommand}"
                   Style="{StaticResource ActionButton}"
                   Width="80"/>
        </StackPanel>

        <Border Grid.Row="2" 
               BorderBrush="#E0E0E0" 
               BorderThickness="1" 
               Margin="0,0,0,20">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid ItemsSource="{Binding Products}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="True"
                        SelectionMode="Extended"
                        SelectionUnit="FullRow"
                        GridLinesVisibility="All"
                        AlternatingRowBackground="#F5F5F5"
                        CellStyle="{StaticResource DataGridCellStyle}"
                        RowHeaderWidth="0"
                        CanUserDeleteRows="True"
                        IsEnabled="{Binding IsNotSaving}"
                        MinWidth="1000">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource Product_BulkAdd_BarcodeTools}" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{DynamicResource Product_GenerateBarcode}"
                                           Command="{Binding DataContext.GenerateBarcodeCommand, 
                                               RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}"
                                           Style="{StaticResource ActionButton}"
                                           Padding="5,2"
                                           Height="25"
                                           Margin="2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource Product_Barcode}" 
                                         Binding="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                         Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource Product_Name}" 
                                         Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Product_PurchasePrice}" 
                                         Binding="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged,
                                                  StringFormat=C2}"
                                         Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource Product_SalePrice}" 
                                         Binding="{Binding SalePrice, UpdateSourceTrigger=PropertyChanged,
                                                  StringFormat=C2}"
                                         Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource Product_CurrentStock}" 
                                         Binding="{Binding CurrentStock, UpdateSourceTrigger=PropertyChanged}"
                                         Width="100"/>
                        <DataGridComboBoxColumn Header="Plants/Hardscape"
                                             ItemsSource="{Binding Source={StaticResource PlantsHardscapeCategoriesViewSource}}"
                                             DisplayMemberPath="Name"
                                             SelectedValuePath="CategoryId"
                                             SelectedValueBinding="{Binding PlantsHardscapeId, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"/>
                        <DataGridComboBoxColumn Header="Local/Imported"
                                             ItemsSource="{Binding Source={StaticResource LocalImportedCategoriesViewSource}}"
                                             DisplayMemberPath="Name"
                                             SelectedValuePath="CategoryId"
                                             SelectedValueBinding="{Binding LocalImportedId, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"/>
                        <DataGridComboBoxColumn Header="Indoor/Outdoor"
                                             ItemsSource="{Binding Source={StaticResource IndoorOutdoorCategoriesViewSource}}"
                                             DisplayMemberPath="Name"
                                             SelectedValuePath="CategoryId"
                                             SelectedValueBinding="{Binding IndoorOutdoorId, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"/>
                        <DataGridComboBoxColumn Header="Plant Family"
                                             ItemsSource="{Binding Source={StaticResource PlantFamilyCategoriesViewSource}}"
                                             DisplayMemberPath="Name"
                                             SelectedValuePath="CategoryId"
                                             SelectedValueBinding="{Binding PlantFamilyId, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"/>
                        <DataGridComboBoxColumn Header="Detail"
                                             ItemsSource="{Binding Source={StaticResource DetailCategoriesViewSource}}"
                                             DisplayMemberPath="Name"
                                             SelectedValuePath="CategoryId"
                                             SelectedValueBinding="{Binding DetailId, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="3" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <TextBlock Text="{DynamicResource Product_BulkAdd_TotalItems}"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Products.Count}"
                         FontWeight="Bold"
                         Margin="5,0,0,0"
                         VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                         Margin="20,0,0,0"
                         Foreground="#666666"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" 
                      Orientation="Horizontal">
                <Button Content="{DynamicResource Product_BulkAdd_ImportFromExcel}"
                       Command="{Binding ImportFromExcelCommand}"
                       Style="{StaticResource ActionButton}"
                       Height="35"
                       Width="120"
                       Margin="0,0,10,0"/>
                <Button Content="{DynamicResource Product_Save}"
                       Command="{Binding SaveCommand}"
                       Style="{StaticResource ActionButton}"
                       Height="35"
                       Width="120"
                       Background="#28A745"
                       IsEnabled="{Binding IsNotSaving}"
                       Margin="0,0,10,0"/>
                <Button Content="{DynamicResource Transaction_Cancel}"
                       IsCancel="True"
                       Height="35"
                       Width="80"
                       Style="{StaticResource ActionButton}"
                       Background="#DC3545"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.RowSpan="4" 
             Background="#80000000"
             Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White"
                   CornerRadius="4"
                   Padding="20"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True"
                               Width="200"
                               Height="2"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding StatusMessage}"
                             HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>