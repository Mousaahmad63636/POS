<Window x:Class="QuickTechSystems.WPF.Views.ReturnItemSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Items to Return" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Select Items to Return"
                     FontSize="20"
                     FontWeight="Bold"
                     Margin="0,0,0,10"/>
            <TextBlock Text="Select items and specify quantities to return"
                     Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                     Margin="0,0,0,20"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  Margin="0,0,0,20">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Select" 
                                      Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      Width="60"/>
                <DataGridTextColumn Header="Product" 
                                  Binding="{Binding ProductName}"
                                  Width="*"/>
                <DataGridTextColumn Header="Barcode" 
                                  Binding="{Binding ProductBarcode}"
                                  Width="120"/>
                <DataGridTextColumn Header="Original Qty" 
                                  Binding="{Binding OriginalQuantity}"
                                  Width="100"
                                  IsReadOnly="True"/>
                <DataGridTextColumn Header="Previously Returned" 
                                  Binding="{Binding ReturnedQuantity}"
                                  Width="120"
                                  IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Return Qty" 
                                      Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ReturnQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsSelected}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Unit Price" 
                                  Binding="{Binding UnitPrice, StringFormat=C2}"
                                  Width="100"
                                  IsReadOnly="True"/>
                <DataGridTextColumn Header="Refund Amount" 
                                  Binding="{Binding RefundAmount, StringFormat=C2}"
                                  Width="120"
                                  IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Return Reason" 
                                      Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsSelected}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Process Return"
                    Click="OkButton_Click"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    Width="80"
                    Height="35"/>
        </StackPanel>
    </Grid>
</Window>