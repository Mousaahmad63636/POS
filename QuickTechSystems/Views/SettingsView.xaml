<UserControl x:Class="QuickTechSystems.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="RootGrid" Margin="20">
                <TabControl>
                    <!-- Backup Tab -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="{DynamicResource Settings_Backup}"/>
                        </TabItem.Header>
                        <Grid Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Manual Backup Section -->
                            <Border Grid.Row="0" 
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    Background="White"
                                    Padding="20"
                                    Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Settings_ManualBackup}" 
                                               Margin="0,0,0,16"/>

                                    <TextBlock Text="{Binding LastBackupStatus}"
                                               Margin="0,0,0,16"/>

                                    <Button Command="{Binding BackupNowCommand}"
                                            Width="150"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{DynamicResource Settings_BackupNow}"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Restore Section -->
                            <Border Grid.Row="2" 
                                    BorderBrush="Gray"
                                    BorderThickness="1"
                                    Background="White"
                                    Padding="20">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Settings_RestoreBackup}" 
                                               Margin="0,0,0,16"/>

                                    <Button Command="{Binding RestoreCommand}"
                                            Width="180"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{DynamicResource Settings_RestoreFromBackup}"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- Business Settings Tab -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="{DynamicResource Settings_BusinessSettings}"/>
                        </TabItem.Header>
                        <Grid Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border BorderBrush="Gray"
                                    BorderThickness="1"
                                    Background="White"
                                    Padding="20"
                                    Grid.Row="0"
                                    Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{DynamicResource Settings_FilterByGroup}" 
                                               VerticalAlignment="Center"/>

                                    <ComboBox Grid.Column="1"
                                              Margin="16,0"
                                              ItemsSource="{Binding Groups}"
                                              SelectedItem="{Binding SelectedGroup}"
                                              VerticalAlignment="Center"/>

                                    <Button Grid.Column="3"
                                            Command="{Binding InitializeBusinessSettingsCommand}">
                                        <TextBlock Text="{DynamicResource Settings_InitializeDefault}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Company Logo Section -->
                            <Border BorderBrush="Gray"
                                    BorderThickness="1"
                                    Background="White"
                                    Padding="20"
                                    Grid.Row="1"
                                    Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Company Logo" 
                                               Margin="0,0,0,16"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Logo Preview -->
                                        <Border Grid.Column="0" 
                                                BorderBrush="Gray" 
                                                BorderThickness="1" 
                                                Padding="10"
                                                MaxHeight="150"
                                                MaxWidth="300"
                                                HorizontalAlignment="Left">
                                            <Image Source="{Binding LogoImage, Converter={StaticResource ByteArrayToImageSourceConverter}}" 
                                                   Stretch="Uniform" 
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>

                                        <!-- Upload Button -->
                                        <Button Grid.Column="1"
                                                Command="{Binding UploadLogoCommand}"
                                                Margin="16,0,0,0"
                                                VerticalAlignment="Bottom">
                                            <TextBlock Text="Upload Logo"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Recommended size: 300x150 pixels, PNG format with transparent background"
                                               Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Main Content -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>

                                <!-- Settings List -->
                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        Background="White"
                                        Margin="0,0,20,0">
                                    <DataGrid ItemsSource="{Binding BusinessSettings}"
                                              SelectedItem="{Binding SelectedBusinessSetting}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="{DynamicResource Settings_Key}" 
                                                               Binding="{Binding Key}"
                                                               Width="150"/>
                                            <DataGridTextColumn Header="{DynamicResource Settings_Value}" 
                                                               Binding="{Binding Value}"
                                                               Width="*"/>
                                            <DataGridTextColumn Header="{DynamicResource Settings_Group}" 
                                                               Binding="{Binding Group}"
                                                               Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                                <!-- Setting Details -->
                                <Border Grid.Column="1" 
                                        BorderBrush="Gray"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="20">
                                    <StackPanel IsEnabled="{Binding IsEditing}">
                                        <TextBlock Text="{DynamicResource Settings_SettingDetails}" 
                                                   Margin="0,0,0,16"/>

                                        <TextBlock Text="{DynamicResource Settings_Key}"/>
                                        <TextBox Text="{Binding SelectedBusinessSetting.Key}"
                                                 Margin="0,0,0,10"
                                                 IsEnabled="False"/>

                                        <TextBlock Text="{DynamicResource Settings_Value}"/>
                                        <TextBox Text="{Binding SelectedBusinessSetting.Value}"
                                                 Margin="0,0,0,10"/>

                                        <TextBlock Text="{DynamicResource Settings_Description}"/>
                                        <TextBox Text="{Binding SelectedBusinessSetting.Description}"
                                                 Margin="0,0,0,10"
                                                 Height="60"
                                                 IsEnabled="False"/>

                                        <TextBlock Text="{DynamicResource Settings_Group}"/>
                                        <TextBox Text="{Binding SelectedBusinessSetting.Group}"
                                                 Margin="0,0,0,10"
                                                 IsEnabled="False"/>

                                        <TextBlock Text="{DynamicResource Settings_ExchangeRate}"/>
                                        <TextBox Text="{Binding ExchangeRate}"
                                                 Margin="0,0,0,10"/>

                                        <Button Command="{Binding SaveBusinessSettingCommand}"
                                                HorizontalAlignment="Right"
                                                Margin="0,16,0,0">
                                            <TextBlock Text="{DynamicResource Settings_SaveChanges}"/>
                                        </Button>

                                        <Button Command="{Binding SaveExchangeRateCommand}"
                                                HorizontalAlignment="Right"
                                                Margin="0,8,0,0">
                                            <TextBlock Text="{DynamicResource Settings_SaveExchangeRate}"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- System Preferences Tab -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="{DynamicResource Settings_SystemPreferences}"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                            <StackPanel>
                                <!-- Language Settings -->
                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="20"
                                        Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Settings_Language}" 
                                                   Margin="0,0,0,16"/>

                                        <TextBlock Text="{DynamicResource Settings_SelectLanguage}"/>
                                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                                  SelectedValue="{Binding SelectedLanguage}"
                                                  SelectedValuePath="Code"
                                                  Margin="0,0,0,16">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding NativeName}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- Theme Settings -->
                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="20"
                                        Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Settings_Theme}" 
                                                   Margin="0,0,0,16"/>

                                        <TextBlock Text="{DynamicResource Settings_ApplicationTheme}"/>
                                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                                  SelectedItem="{Binding CurrentTheme}"
                                                  Margin="0,0,0,16"/>
                                    </StackPanel>
                                </Border>

                                <!-- Restaurant Mode Settings -->
                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="20"
                                        Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Settings_TransactionMode}" 
                                                   Margin="0,0,0,16"/>

                                        <CheckBox Content="{DynamicResource Settings_EnableRestaurantMode}" 
                                                 IsChecked="{Binding IsRestaurantMode}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="{DynamicResource Settings_RestaurantModeDescription}" 
                                                  TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Date & Time -->
                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="20"
                                        Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Settings_DateAndTime}" 
                                                   Margin="0,0,0,16"/>

                                        <TextBlock Text="{DynamicResource Settings_DateFormat}"/>
                                        <ComboBox ItemsSource="{Binding DateFormats}"
                                                  SelectedItem="{Binding DateFormat}"
                                                  Margin="0,0,0,16"/>

                                        <TextBlock Text="{DynamicResource Settings_TimeFormat}"/>
                                        <ComboBox ItemsSource="{Binding TimeFormats}"
                                                  SelectedItem="{Binding TimeFormat}"
                                                  Margin="0,0,0,16"/>
                                    </StackPanel>
                                </Border>

                                <!-- Notifications -->
                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="20"
                                        Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Settings_Notifications}" 
                                                   Margin="0,0,0,16"/>

                                        <CheckBox Content="{DynamicResource Settings_EnableNotifications}"
                                                 IsChecked="{Binding NotificationsEnabled}"
                                                 Margin="0,0,0,8"/>

                                        <CheckBox Content="{DynamicResource Settings_EnableSoundEffects}"
                                                 IsChecked="{Binding SoundEffectsEnabled}"
                                                 Margin="0,0,0,8"/>
                                    </StackPanel>
                                </Border>

                                <!-- Reset Button -->
                                <Button Command="{Binding ResetPreferencesCommand}"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,20">
                                    <TextBlock Text="{DynamicResource Settings_ResetToDefault}"/>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>