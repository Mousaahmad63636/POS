<UserControl x:Class="QuickTechSystems.WPF.Views.DrawerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:LessThanZeroConverter x:Key="LessThanZeroConverter"/>

        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#007BFF"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#6C757D"/>
        <SolidColorBrush x:Key="TextColor" Color="#343A40"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#28A745"/>
        <SolidColorBrush x:Key="DangerColor" Color="#DC3545"/>
        <SolidColorBrush x:Key="GrayTextColor" Color="#6C757D"/>
        <SolidColorBrush x:Key="LightGrayBg" Color="#E9ECEF"/>
        <SolidColorBrush x:Key="InfoColor" Color="#17A2B8"/>

        <!-- DataGrid Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource LightGrayBg}"/>
            <Setter Property="RowHeight" Value="35"/>
        </Style>


        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- InfoCard Style -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LightGrayBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{DynamicResource Drawer_Title}"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="{StaticResource PrimaryColor}"/>
            <TextBlock Text="Monitor and manage your cash drawer"
                     Foreground="{StaticResource GrayTextColor}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Main Content -->
            <Border Background="White"
                   BorderBrush="{StaticResource BorderColor}"
                   BorderThickness="1"
                   CornerRadius="5"
                   Margin="0,0,20,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Balance Display -->
                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">
                        <Border Style="{StaticResource InfoCard}">
                            <StackPanel Margin="10">
                                <TextBlock Text="{DynamicResource Drawer_CurrentBalance}"
                                         FontSize="14"
                                         Foreground="{StaticResource TextColor}"/>
                                <TextBlock Text="{Binding CurrentDrawer.CurrentBalance, StringFormat=C2}"
                                         FontSize="20"
                                         FontWeight="Bold"
                                         Foreground="{StaticResource SuccessColor}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InfoCard}">
                            <StackPanel Margin="10">
                                <TextBlock Text="{DynamicResource Drawer_ExpectedBalance}"
                                         FontSize="14"
                                         Foreground="{StaticResource TextColor}"/>
                                <TextBlock Text="{Binding CurrentDrawer.ExpectedBalance, StringFormat=C2}"
                                         FontSize="20"
                                         FontWeight="Bold"
                                         Foreground="{StaticResource PrimaryColor}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InfoCard}">
                            <StackPanel Margin="10">
                                <TextBlock Text="{DynamicResource Drawer_Difference}"
                                         FontSize="14"
                                         Foreground="{StaticResource TextColor}"/>
                                <TextBlock Text="{Binding CurrentDrawer.Difference, StringFormat=C2}"
                                         FontSize="20"
                                         FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDrawer.Difference}" Value="0">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentDrawer.Difference, Converter={StaticResource LessThanZeroConverter}}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Status Info -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding StatusMessage}"
                                 Foreground="{StaticResource TextColor}"
                                 VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2" 
                                 Text="{Binding CurrentDrawer.OpenedAt, StringFormat='Opened: {0:g}'}"
                                 Foreground="{StaticResource TextColor}"
                                 VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Transaction History -->
                    <DataGrid Grid.Row="2"
                            ItemsSource="{Binding DrawerHistory}"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Drawer_Column_Time}" 
                                             Binding="{Binding Timestamp, StringFormat=t}"
                                             Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource Drawer_Column_Action}" 
                                             Binding="{Binding ActionType}"
                                             Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource Drawer_Column_Description}" 
                                             Binding="{Binding Description}"
                                             Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Drawer_Column_Amount}" 
                                             Binding="{Binding Amount, StringFormat=C2}"
                                             Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource Drawer_Column_Balance}" 
                                             Binding="{Binding ResultingBalance, StringFormat=C2}"
                                             Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Actions Panel -->
            <StackPanel Grid.Column="1">
                <Button Content="{DynamicResource Drawer_OpenDrawer}"
                       Command="{Binding OpenDrawerCommand}"
                       Style="{StaticResource ActionButton}"
                       Background="{StaticResource SuccessColor}"
                       IsEnabled="{Binding CanOpenDrawer}"/>

                <Button Content="{DynamicResource Drawer_AddCash}"
                       Command="{Binding AddCashCommand}"
                       Style="{StaticResource ActionButton}"
                       Background="{StaticResource InfoColor}"
                       IsEnabled="{Binding IsDrawerOpen}"/>

                <Button Content="{DynamicResource Drawer_RemoveCash}"
                       Command="{Binding RemoveCashCommand}"
                       Style="{StaticResource ActionButton}"
                       Background="{StaticResource DangerColor}"
                       IsEnabled="{Binding IsDrawerOpen}"/>

                <Button Content="{DynamicResource Drawer_CloseDrawer}"
                       Command="{Binding CloseDrawerCommand}"
                       Style="{StaticResource ActionButton}"
                       Background="{StaticResource PrimaryColor}"
                       IsEnabled="{Binding IsDrawerOpen}"/>

                <Button Content="{DynamicResource Drawer_PrintReport}"
                       Command="{Binding PrintReportCommand}"
                       Style="{StaticResource ActionButton}"
                       Background="{StaticResource GrayTextColor}"
                       IsEnabled="{Binding IsDrawerOpen}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>