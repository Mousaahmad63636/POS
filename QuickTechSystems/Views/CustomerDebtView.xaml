<UserControl x:Class="QuickTechSystems.WPF.Views.CustomerDebtView"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
            xmlns:converters="clr-namespace:QuickTechSystems.WPF.Converters"
            mc:Ignorable="d" d:DesignWidth="1200" Height="800">

    <UserControl.Resources>
        <converters:CurrencyConverter x:Key="CurrencyConverter"/>

        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#007BFF"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#6C757D"/>
        <SolidColorBrush x:Key="TextColor" Color="#343A40"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#28A745"/>
        <SolidColorBrush x:Key="DangerColor" Color="#DC3545"/>
        <SolidColorBrush x:Key="GrayTextColor" Color="#6C757D"/>

        <!-- DataGrid Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BackgroundColor}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#E9ECEF"/>
            <Setter Property="RowHeight" Value="35"/>
        </Style>


        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource SecondaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="0,0,0,2"
                                Margin="0,0,20,0">
                            <ContentPresenter x:Name="ContentSite"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            ContentSource="Header"
                                            Margin="10,5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{DynamicResource Debt_Title}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryColor}"/>
            <TextBlock Text="{DynamicResource Debt_Subtitle}"
                       Foreground="{StaticResource GrayTextColor}"/>
        </StackPanel>

        <Grid Grid.Row="1" RenderTransformOrigin="0.496,0.504">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="580"/>
            </Grid.ColumnDefinitions>

            <!-- Customer List -->
            <Border Background="White"
                   BorderBrush="{StaticResource BorderColor}"
                   BorderThickness="1"
                   CornerRadius="5"
                   Margin="0,0,20,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Box -->
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                           Margin="10"
                           Padding="10,8"
                           FontSize="14">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Resources>
                                    <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="{DynamicResource Debt_CustomerSearch}" 
                                                      Foreground="{StaticResource GrayTextColor}"
                                                      Margin="5,0,0,0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <DataGrid Grid.Row="1"
                            ItemsSource="{Binding CustomersWithDebt}"
                            SelectedItem="{Binding SelectedCustomer}"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            BorderThickness="0" RenderTransformOrigin="0.5,0.5" Margin="0,0,5,0">
                        <DataGrid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform AngleY="0.171"/>
                                <RotateTransform/>
                                <TranslateTransform Y="0.83"/>
                            </TransformGroup>
                        </DataGrid.RenderTransform>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Debt_Column_Customer}" 
                                             Binding="{Binding Name}"
                                             Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Debt_Column_BalanceUSD}" 
                                             Binding="{Binding Balance, StringFormat=C2}"
                                             Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource Debt_Column_BalanceLBP}" 
                                             Binding="{Binding Balance, 
                                                       Converter={StaticResource CurrencyConverter}, 
                                                       ConverterParameter=LBP}"
                                             Width="150"/>
                            <DataGridTextColumn Header="{DynamicResource Debt_Column_Phone}" 
                                             Binding="{Binding Phone}"
                                             Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Details Panel -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="240.45"/>
                    <RowDefinition Height="22.97"/>
                    <RowDefinition Height="119*"/>
                    <RowDefinition Height="310*"/>
                </Grid.RowDefinitions>

                <!-- Customer Info and Payment Section -->
                <Border Background="White"
                       BorderBrush="{StaticResource BorderColor}"
                       BorderThickness="1"
                       CornerRadius="5"
                       Padding="15"
                       Margin="0,0,0,20" RenderTransformOrigin="0.5,0.5" Grid.RowSpan="2">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="-0.141"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <StackPanel>
                        <!-- Customer Info -->
                        <TextBlock Text="{Binding SelectedCustomer.Name}"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextColor}"/>

                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{DynamicResource Debt_BalanceUSD}"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextColor}"/>
                            <TextBlock Grid.Column="1"
                                    Text="{Binding SelectedCustomer.Balance, StringFormat=C2}"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource DangerColor}"/>

                            <TextBlock Grid.Row="1"
                                    Text="{DynamicResource Debt_BalanceLBP}"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextColor}"/>
                            <TextBlock Grid.Row="1"
                                    Grid.Column="1"
                                    Text="{Binding TotalAmountLBP}"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource DangerColor}"/>
                        </Grid>

                        <!-- Payment Input -->
                        <TextBlock Text="{DynamicResource Debt_PaymentAmountLabel}"
                                Margin="0,20,0,5"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextColor}"/>
                        <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                               FontSize="18"
                               Padding="10,8"/>

                        <Button Content="{DynamicResource Debt_ProcessPayment}"
                               Command="{Binding ProcessPaymentCommand}"
                               Height="40"
                               Margin="0,10,0,0"
                               Background="{StaticResource SuccessColor}"
                               Style="{StaticResource BaseButton}"/>
                    </StackPanel>
                </Border>

                <!-- History Tabs -->
                <TabControl Grid.Row="1" Margin="0,23,0,0" Grid.RowSpan="3">
                    <!-- Transactions Tab -->
                    <TabItem Header="{DynamicResource Debt_TransactionHistoryTab}">
                        <DataGrid ItemsSource="{Binding TransactionHistory}"
                               AutoGenerateColumns="False"
                               IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_Date}" 
                                                 Binding="{Binding TransactionDate, StringFormat=g}"
                                                 Width="140"/>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_Type}" 
                                                 Binding="{Binding TransactionType}"
                                                 Width="80"/>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_AmountUSD}" 
                                                 Binding="{Binding TotalAmount, StringFormat=C2}"
                                                 Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_AmountLBP}" 
                                                 Binding="{Binding TotalAmount, 
                                                           Converter={StaticResource CurrencyConverter}, 
                                                           ConverterParameter=LBP}"
                                                 Width="120"/>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="2">
                                                <Button Content="{DynamicResource Debt_DetailsButton}"
                        Command="{Binding DataContext.ViewTransactionDetailCommand, 
                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}"
                        Background="{StaticResource PrimaryColor}"
                        Style="{StaticResource BaseButton}"
                        Padding="10,5"
                        Margin="0,0,5,0"/>
                                                <Button Content="{DynamicResource Debt_PrintButton}"
                        Command="{Binding DataContext.PrintTransactionCommand, 
                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding}"
                        Background="{StaticResource SuccessColor}"
                        Style="{StaticResource BaseButton}"
                        Padding="10,5"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- Payments Tab -->
                    <TabItem Header="{DynamicResource Debt_PaymentHistoryTab}">
                        <DataGrid ItemsSource="{Binding PaymentHistory}"
                               AutoGenerateColumns="False"
                               IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_Date}" 
                                                 Binding="{Binding PaymentDate, StringFormat=g}"
                                                 Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_AmountUSD}" 
                                                 Binding="{Binding Amount, StringFormat=C2}"
                                                 Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_AmountLBP}"
                                                 Binding="{Binding Amount, 
                                                           Converter={StaticResource CurrencyConverter}, 
                                                           ConverterParameter=LBP}"
                                                 Width="120"/>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_Method}" 
                                                 Binding="{Binding PaymentMethod}"
                                                 Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Debt_Column_Notes}" 
                                                 Binding="{Binding Notes}"
                                                 Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</UserControl>