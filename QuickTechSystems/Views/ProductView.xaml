<UserControl x:Class="QuickTechSystems.WPF.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:QuickTechSystems.WPF.Views"
             xmlns:conv="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:LowStockConverter x:Key="LowStockConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Product List -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Product_Title}"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- Search Box -->
            <TextBox Grid.Row="1" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"
                     Padding="5"
                     VerticalContentAlignment="Center">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Resources>
                            <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                <VisualBrush.Visual>
                                    <TextBlock Text="Search products..." 
                                               Foreground="Gray"
                                               Margin="5,0,0,0"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <!-- Red background for out of stock -->
                            <DataTrigger Binding="{Binding CurrentStock}" Value="0">
                                <Setter Property="Background" Value="#FFFFCDD2"/>
                                <Setter Property="Foreground" Value="#FFB71C1C"/>
                            </DataTrigger>

                            <!-- Orange background for low stock -->
                            <DataTrigger Binding="{Binding Converter={StaticResource LowStockConverter}}" Value="True">
                                <Setter Property="Background" Value="#FFFFF3E0"/>
                                <Setter Property="Foreground" Value="#FFEF6C00"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Product_Barcode}" 
                                        Binding="{Binding Barcode}"
                                        Width="100"/>
                    <DataGridTextColumn Header="{DynamicResource Product_Name}" 
                                        Binding="{Binding Name}"
                                        Width="*"/>
                    <DataGridTextColumn Header="{DynamicResource Product_Category}" 
                                        Binding="{Binding CategoryName}"
                                        Width="120"/>
                    <DataGridTextColumn Header="{DynamicResource Product_Supplier}" 
                                        Binding="{Binding SupplierName}"
                                        Width="120"/>
                    <DataGridTextColumn Header="{DynamicResource Product_CurrentStock}" 
                                        Binding="{Binding CurrentStock}"
                                        Width="80"/>
                    <DataGridTextColumn Header="{DynamicResource Product_MinimumStock}" 
                                        Binding="{Binding MinimumStock}"
                                        Width="80"/>
                    <DataGridTextColumn Header="Speed" 
                                        Binding="{Binding Speed}"
                                        Width="80"/>
                    <DataGridTextColumn Header="{DynamicResource Product_SalePrice}" 
                                        Binding="{Binding SalePrice, StringFormat=C}"
                                        Width="100"/>
                    <DataGridCheckBoxColumn Header="{DynamicResource Product_IsActive}" 
                                            Binding="{Binding IsActive}"
                                            Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="{DynamicResource Product_AddNew}" 
                        Command="{Binding AddCommand}"
                        Margin="0,0,10,0"/>
                <Button Content="Edit Product" 
                        Command="{Binding EditCommand}"
                        Margin="0,0,10,0"/>
                <Button Content="Bulk Add Products"
                        Command="{Binding BulkAddCommand}"
                        Margin="0,0,10,0"/>
                <Button Content="Delete Product"
                        Command="{Binding DeleteCommand}"
                        Margin="0,0,10,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>