<UserControl x:Class="QuickTechSystems.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="1232"
             FlowDirection="{Binding CurrentFlowDirection}">

    <UserControl.Resources>
        <!-- Color System -->
        <SolidColorBrush x:Key="Primary" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="Secondary" Color="#7C3AED"/>
        <SolidColorBrush x:Key="Success" Color="#059669"/>
        <SolidColorBrush x:Key="Warning" Color="#D97706"/>
        <SolidColorBrush x:Key="Info" Color="#0EA5E9"/>
        <SolidColorBrush x:Key="Dark" Color="#1E293B"/>

        <!-- Text Colors -->
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextDark" Color="#0F172A"/>

        <!-- Background Colors -->
        <SolidColorBrush x:Key="BackgroundPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundSecondary" Color="#F1F5F9"/>

        <!-- Effects -->
        <DropShadowEffect x:Key="CardShadow" 
                         BlurRadius="20"
                         Direction="315"
                         Opacity="0.1"
                         ShadowDepth="8"
                         Color="#0F172A"/>

        <!-- Store Header Styles -->
        <Style x:Key="StoreHeaderContainer" TargetType="Grid">
            <Setter Property="Background" Value="{StaticResource BackgroundPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="StoreNameText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
        </Style>

        <Style x:Key="TerminalText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="HeaderDateTime" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Updated Modern Card Style -->
        <Style x:Key="ModernCard" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BackgroundPrimary}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="Width" Value="240"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{StaticResource TextSecondary}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" 
                                        Direction="315"
                                        Opacity="0.15" 
                                        ShadowDepth="5"
                                        Color="#0F172A"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Path Width="28" Height="28" 
                                  Fill="{StaticResource TextDark}"
                                  Data="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}"
                                  Stretch="Uniform"
                                  Margin="0,0,12,0">
                                        <Path.Effect>
                                            <DropShadowEffect BlurRadius="2" 
                                                    Direction="315"
                                                    Opacity="0.2" 
                                                    ShadowDepth="1"
                                                    Color="#0F172A"/>
                                        </Path.Effect>
                                    </Path>
                                    <TextBlock Text="{TemplateBinding Content}"
                                     FontSize="16.5"
                                     FontWeight="SemiBold"
                                     VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="1" 
                                                    Direction="315"
                                                    Opacity="0.15" 
                                                    ShadowDepth="1"
                                                    Color="#0F172A"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                 Text="View Details →"
                                 FontSize="13"
                                 Foreground="{StaticResource TextSecondary}"
                                 VerticalAlignment="Bottom">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="1" 
                                                Direction="315"
                                                Opacity="0.1" 
                                                ShadowDepth="1"
                                                Color="#0F172A"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" 
                                                Direction="315"
                                                Opacity="0.2" 
                                                ShadowDepth="8"
                                                Color="#0F172A"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Headers -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="Margin" Value="15,30,15,15"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundSecondary}">
        <!-- Store Header with Clock -->
        <Grid Style="{StaticResource StoreHeaderContainer}">
            <Border Background="{StaticResource BackgroundPrimary}"
                    Effect="{StaticResource CardShadow}"
                    Padding="16">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top"
                              Margin="10,10,10,0">
                        <!-- Left Section - Store Info -->
                        <StackPanel Orientation="Horizontal"
                                  VerticalAlignment="Center"
                                  Margin="10,0,20,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Dashboard_Title}" 
                                         Style="{StaticResource StoreNameText}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Center Section - Date & Time - Keep unchanged -->
                        <StackPanel Orientation="Horizontal"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                            <!-- Date Display -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                <Path Width="20" Height="20" 
                                    Fill="{StaticResource TextSecondary}" 
                                    Margin="0,0,8,0"
                                    Stretch="Uniform"
                                    Data="M9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/>
                                <TextBlock x:Name="DateDisplay" 
                                         Style="{StaticResource HeaderDateTime}"/>
                            </StackPanel>

                            <!-- Time Display -->
                            <StackPanel Orientation="Horizontal">
                                <Path Width="20" Height="20" 
                                    Fill="{StaticResource TextSecondary}" 
                                    Margin="0,0,8,0"
                                    Stretch="Uniform"
                                    Data="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                                <TextBlock x:Name="TimeDisplay" 
                                         Style="{StaticResource HeaderDateTime}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <ScrollViewer Margin="0,80,0,0">
            <StackPanel>
                <!-- Main Operations Section -->
                <TextBlock Text="{DynamicResource MainWindow_MainOperations}" Style="{StaticResource SectionHeader}"/>
                <WrapPanel Margin="10,0">
                    <Button Content="{DynamicResource MainWindow_Transactions}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Transactions"
                            Tag="M17 2H7C5.9 2 5 2.9 5 4v16c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 18H7V4h10v16zm-1-7h-8v2h8v-2zm0-4h-8v2h8V9zm0-4h-8v2h8V5z"/>
                    <Button Content="{DynamicResource MainWindow_Products}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Products"
                            Tag="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zm-8-2h2v-4h4v-2h-4V7h-2v4H7v2h4z"/>
                </WrapPanel>

                <!-- Finance Section -->
                <TextBlock Text="{DynamicResource MainWindow_Finance}" Style="{StaticResource SectionHeader}"/>
                <WrapPanel Margin="10,0">
                    <Button Content="{DynamicResource MainWindow_CustomerDebt}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="CustomerDebt"
                            Tag="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
                    <Button Content="{DynamicResource MainWindow_Profit}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Profit"
                            Tag="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/>
                    <Button Content="{DynamicResource MainWindow_Drawer}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Drawer"
                            Tag="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                    <Button Content="{DynamicResource MainWindow_Expenses}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Expenses"
                            Tag="M20 2H4c-1.11 0-2 .89-2 2v11c0 1.11.89 2 2 2h4v5l4-2 4 2v-5h4c1.11 0 2-.89 2-2V4c0-1.11-.89-2-2-2zm0 13H4V4h16v11z"/>
                </WrapPanel>

                <!-- Management Section -->
                <TextBlock Text="{DynamicResource MainWindow_Management}" Style="{StaticResource SectionHeader}"/>
                <WrapPanel Margin="10,0">
                    <Button Content="{DynamicResource MainWindow_Customers}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Customers"
                            Tag="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    <Button Content="{DynamicResource MainWindow_Suppliers}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Suppliers"
                            Tag="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                    <Button Content="{DynamicResource MainWindow_Categories}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Categories"
                            Tag="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2zM9 13H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2z"/>
                    <Button Content="{DynamicResource MainWindow_Employees}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Employees"
                            Tag="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </WrapPanel>

                <!-- Reports Section -->
                <TextBlock Text="{DynamicResource MainWindow_Reports}" Style="{StaticResource SectionHeader}"/>
                <WrapPanel Margin="10,0,10,20">
                    <Button Content="{DynamicResource MainWindow_TransactionHistory}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="TransactionHistory"
                            Tag="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/>
                    <Button Content="{DynamicResource MainWindow_Settings}" Style="{StaticResource ModernCard}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Settings"
                            Tag="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.03-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>