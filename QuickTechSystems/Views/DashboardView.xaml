<UserControl x:Class="QuickTechSystems.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/design/blend/2008"
             xmlns:converters="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <!-- Date and Time Header -->
        <DockPanel>
            <Border DockPanel.Dock="Top" 
                    Margin="20,10,20,0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10">
                <Grid>
                    <StackPanel Orientation="Horizontal" 
                              HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" 
                                  Margin="0,0,24,0">
                            <TextBlock Text="📅 " 
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Dashboard_Date}"/>
                            <TextBlock x:Name="DateDisplay"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏰ "
                                     Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Dashboard_Time}"/>
                            <TextBlock x:Name="TimeDisplay"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,30,20,20">
                    <!-- Sales & Revenue Section -->
                    <TextBlock Text="{DynamicResource Dashboard_SalesRevenue}" 
                             FontSize="24"
                             Margin="0,30,0,15"/>
                    <WrapPanel>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Quotes">
                            <StackPanel>
                                <TextBlock Text="📝 Quotes" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Business Operations Section -->
                    <TextBlock Text="{DynamicResource Dashboard_BusinessOperations}" 
                             FontSize="24"
                             Margin="0,30,0,15"/>
                    <WrapPanel>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Drawer">
                            <StackPanel>
                                <TextBlock Text="🏦 Cash Flow" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="CustomerDebt">
                            <StackPanel>
                                <TextBlock Text="💳 Accounts Receivable" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Expenses">
                            <StackPanel>
                                <TextBlock Text="💸 Business Expenses" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Inventory Management Section -->
                    <TextBlock Text="{DynamicResource Dashboard_InventoryManagement}" 
                             FontSize="24"
                             Margin="0,30,0,15"/>
                    <WrapPanel>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Products">
                            <StackPanel>
                                <TextBlock Text="📦 Products" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Categories">
                            <StackPanel>
                                <TextBlock Text="📂 Product Categories" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Suppliers">
                            <StackPanel>
                                <TextBlock Text="🚚 Vendor Management" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Business Management Section -->
                    <TextBlock Text="{DynamicResource Dashboard_BusinessManagement}" 
                             FontSize="24"
                             Margin="0,30,0,15"/>
                    <WrapPanel Margin="0,0,0,20">
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Employees">
                            <StackPanel>
                                <TextBlock Text="👥 Workforce Management" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Profit">
                            <StackPanel>
                                <TextBlock Text="📈 Business Performance" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Height="130"
                                Width="300"
                                Margin="10"
                                Command="{Binding NavigateCommand}" 
                                CommandParameter="Settings">
                            <StackPanel>
                                <TextBlock Text="⚙️ System Preferences" Margin="0,0,0,12"/>
                                <TextBlock Text="{DynamicResource Dashboard_ViewDetails}" 
                                         FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Loading Overlay -->
        <Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" 
                       VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" 
                           Width="120" 
                           Margin="0,0,0,16"/>
                <TextBlock Text="{DynamicResource Dashboard_Loading}" 
                         Foreground="White" 
                         FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Error Message -->
        <Border Background="LightPink"
                BorderBrush="Red"
                BorderThickness="1"
                Padding="16"
                Margin="20"
                MaxWidth="400"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠️" 
                         FontSize="16"
                         Margin="0,0,8,0"/>
                <TextBlock Text="{Binding ErrorMessage}"
                         TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>