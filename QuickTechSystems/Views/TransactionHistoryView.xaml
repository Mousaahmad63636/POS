<UserControl x:Class="QuickTechSystems.WPF.Views.TransactionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="544.257" d:DesignWidth="1048.944">

    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#2C3E50"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#6C757D"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#DEE2E6"/>
        <SolidColorBrush x:Key="DeleteButtonColor" Color="#DC3545"/>
        <SolidColorBrush x:Key="DeleteButtonHoverColor" Color="#C82333"/>

        <!-- Header Style -->
        <Style x:Key="PageHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- SubHeader Style -->
        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- DataGrid Styles -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PrimaryBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- Column Header Style -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Delete Button Style -->
        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource DeleteButtonColor}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DeleteButtonHoverColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PrimaryBackground}" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource TransactionHistory_Title}"
                       Style="{StaticResource PageHeaderStyle}"
                       AutomationProperties.Name="Transaction History Title"/>
            <TextBlock Text="{DynamicResource TransactionHistory_Subtitle}"
                       Style="{StaticResource SubHeaderStyle}"
                       AutomationProperties.Name="Transaction History Subtitle"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" 
                Background="{StaticResource SecondaryBackground}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8"
                             FontSize="14"
                             ToolTip="Enter text to search transactions by ID, customer, or product"
                             AutomationProperties.Name="Search Transactions">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="Search transactions..."
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="10,0,0,0"
                               Foreground="{StaticResource SecondaryText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Category Filter -->
                <ComboBox Grid.Column="1"
                          Width="200"
                          Margin="0,0,15,0"
                          Padding="10,8"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"
                          ToolTip="Filter transactions by category"
                          AutomationProperties.Name="Category Filter"/>

                <!-- Date Range -->
                <ComboBox Grid.Column="2"
                          Width="200"
                          Margin="0,0,15,0"
                          Padding="10,8"
                          ItemsSource="{Binding DateRanges}"
                          SelectedItem="{Binding SelectedDateRange}"
                          ToolTip="Select date range for transactions"
                          AutomationProperties.Name="Date Range Filter"/>

                <!-- Buttons StackPanel -->
                <StackPanel Grid.Column="3" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- Refresh Button -->
                    <Button Margin="0,0,10,0"
                            Command="{Binding RefreshCommand}"
                            ToolTip="Refresh transaction list">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                                        <Setter Property="Content" Value="{DynamicResource TransactionHistory_RefreshingButton}"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRefreshing}" Value="False">
                                        <Setter Property="Content" Value="{DynamicResource TransactionHistory_RefreshButton}"/>
                                        <Setter Property="IsEnabled" Value="True"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{DynamicResource TransactionHistory_ExportButton}"
                            Command="{Binding ExportCommand}"
                            Margin="0,0,10,0"
                            ToolTip="Export transactions to CSV"
                            AutomationProperties.Name="Export Transactions"/>

                    <Button Content="{DynamicResource TransactionHistory_PrintButton}"
                            Command="{Binding PrintReportCommand}"
                            Margin="0,0,10,0"
                            ToolTip="Print transaction report"
                            AutomationProperties.Name="Print Report"/>

                    <Button Content="Clear Filters"
                            Command="{Binding ClearFiltersCommand}"
                            ToolTip="Reset all filters"
                            AutomationProperties.Name="Clear Filters"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Transactions Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <Grid>
                <DataGrid Style="{StaticResource ModernDataGrid}"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          ItemsSource="{Binding Transactions}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          AutomationProperties.Name="Transaction List">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource TransactionHistory_Column_ID}" 
                                            Binding="{Binding TransactionId}"
                                            Width="80"/>
                        <DataGridTextColumn Header="{DynamicResource TransactionHistory_Column_Date}" 
                                            Binding="{Binding TransactionDate, StringFormat=g}"
                                            Width="150"/>
                        <DataGridTextColumn Header="{DynamicResource TransactionHistory_Column_Customer}" 
                                            Binding="{Binding CustomerName}"
                                            Width="180"/>
                        <DataGridTextColumn Header="{DynamicResource TransactionHistory_Column_Type}" 
                                            Binding="{Binding TransactionType}"
                                            Width="100"/>
                        <DataGridTextColumn Header="{DynamicResource TransactionHistory_Column_Items}" 
                                            Binding="{Binding Details.Count}"
                                            Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{DynamicResource TransactionHistory_Column_Total}" 
                                            Binding="{Binding TotalAmount, StringFormat=C2}"
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{DynamicResource TransactionHistory_Column_Status}" 
                                            Binding="{Binding Status}"
                                            Width="100"/>
                        <DataGridTemplateColumn Width="210">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource TransactionHistory_DetailsButton}"
                                                Style="{StaticResource ActionButton}"
                                                Command="{Binding DataContext.ViewTransactionDetailsCommand, 
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Margin="5,3"
                                                Padding="12,6"
                                                ToolTip="View transaction details"/>
                                        <Button Content="{DynamicResource TransactionHistory_DeleteButton}"
                                                Style="{StaticResource DeleteButton}"
                                                Command="{Binding DataContext.DeleteTransactionCommand, 
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Margin="5,3"
                                                Padding="12,6"
                                                ToolTip="Delete this transaction"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True"
                             Height="20"
                             Width="200"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </ScrollViewer>

        <!-- Summary -->
        <Border Grid.Row="3"
                Background="{StaticResource SecondaryBackground}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock Text="{DynamicResource TransactionHistory_TotalSalesLabel}"
                           Foreground="{StaticResource PrimaryText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Total Sales Label"/>
                <TextBlock Text="{Binding TotalSales, StringFormat=C2}"
                           Foreground="{StaticResource AccentColor}"
                           Margin="5,0,30,0"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Total Sales Value"/>
                <TextBlock Text="{DynamicResource TransactionHistory_TotalProfitLabel}"
                           Foreground="{StaticResource PrimaryText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Total Profit Label"/>
                <TextBlock Text="{Binding TotalProfit, StringFormat=C2}"
                           Foreground="#27AE60"
                           Margin="5,0,0,0"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Total Profit Value"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>