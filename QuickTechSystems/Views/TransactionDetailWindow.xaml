<Window x:Class="QuickTechSystems.WPF.Views.TransactionDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction Details" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Window.Resources>
        <!-- Base TextBlock style for null handling -->
        <Style x:Key="SafeTextBlock" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                    <Setter Property="Text" Value="--"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Label style -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="1" 
            CornerRadius="5" 
            Margin="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Transaction Details"
                      Style="{StaticResource HeaderText}"
                      Margin="0,0,0,20"/>

            <!-- Transaction Info -->
            <Border Grid.Row="1" 
                    Background="#F8F9FA" 
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Transaction #: "
                             Style="{StaticResource LabelText}"
                             Margin="0,0,10,10"/>
                    <TextBlock Grid.Column="1"
                             Text="{Binding TransactionId, TargetNullValue='--'}"
                             Margin="0,0,20,10"/>
                    <TextBlock Grid.Column="2"
                             Text="Date: "
                             Style="{StaticResource LabelText}"
                             Margin="0,0,10,10"/>
                    <TextBlock Grid.Column="3"
                             Text="{Binding TransactionDate, StringFormat=g, TargetNullValue='--'}"
                             Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1"
                             Text="Customer: "
                             Style="{StaticResource LabelText}"
                             Margin="0,0,10,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                             Text="{Binding CustomerName, TargetNullValue='Walk-in Customer'}"
                             Margin="0,0,20,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="2"
                             Text="Status: "
                             Style="{StaticResource LabelText}"
                             Margin="0,0,10,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="3"
                             Text="{Binding Status, TargetNullValue='--'}"/>
                </Grid>
            </Border>

            <!-- Items Grid -->
            <DataGrid Grid.Row="2"
                     ItemsSource="{Binding Details}"
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     Margin="0,0,0,20">
                <DataGrid.Style>
                    <Style TargetType="DataGrid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Details.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <TextBlock Text="No items to display"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{StaticResource GrayTextColor}"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product"
                                      Binding="{Binding ProductName, TargetNullValue='--'}"
                                      Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Quantity"
                                      Binding="{Binding Quantity, TargetNullValue='0'}"
                                      Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Unit Price"
                                      Binding="{Binding UnitPrice, StringFormat=C2, TargetNullValue='$0.00'}"
                                      Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Total"
                                      Binding="{Binding Total, StringFormat=C2, TargetNullValue='$0.00'}"
                                      Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Totals -->
            <Border Grid.Row="3" 
                    Background="#F8F9FA"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="15"
                    HorizontalAlignment="Right">
                <TextBlock Text="{Binding TotalAmount, StringFormat='Total: {0:C2}', TargetNullValue='Total: $0.00'}"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="{StaticResource PrimaryColor}"/>
            </Border>
        </Grid>
    </Border>
</Window>