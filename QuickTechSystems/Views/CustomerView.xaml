<UserControl x:Class="QuickTechSystems.WPF.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:QuickTechSystems.WPF.Views"
             xmlns:converters="clr-namespace:QuickTechSystems.WPF.Converters"
             FlowDirection="{Binding CurrentFlowDirection}"
             mc:Ignorable="d"
             x:Name="CustomerViewRoot">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid x:Name="MainGrid">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="ContentGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="CUSTOMER MANAGEMENT" 
                           HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <!-- Control Panel -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Box -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Search customers..." Foreground="Gray" Margin="5,0,0,0" 
                                   Visibility="{Binding Text.IsEmpty, ElementName=searchBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBox x:Name="searchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 VerticalContentAlignment="Center"/>
                    </Grid>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Add New Customer" 
                                Command="{Binding AddCommand}"
                                Margin="0,0,8,0"
                                MinWidth="160" MinHeight="48"
                                Padding="8,4"/>
                        <Button Content="Refresh" 
                                Command="{Binding LoadCommand}"
                                MinWidth="100" MinHeight="48"
                                Padding="8,4"/>
                    </StackPanel>
                </Grid>

                <!-- Customer Data Grid -->
                <DataGrid Grid.Row="2" 
                          ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          AutoGenerateColumns="False"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          Margin="0,0,0,15"
                          RowHeight="48">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Customer_Name}" 
                                           Binding="{Binding Name}"
                                           Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Customer_Phone}" 
                                           Binding="{Binding Phone}"
                                           Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource Customer_Email}" 
                                           Binding="{Binding Email}"
                                           Width="200"/>
                        <DataGridTextColumn Header="Balance" 
                                           Binding="{Binding Balance, StringFormat=C2}"
                                           Width="120"/>
                        <DataGridCheckBoxColumn Header="{DynamicResource Customer_Active}" 
                                               Binding="{Binding IsActive}"
                                               Width="80"/>
                        <DataGridTemplateColumn Width="330">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Edit" 
                                                Click="EditButton_Click"
                                                Margin="4"
                                                MinHeight="36"
                                                MinWidth="60"
                                                Padding="4,2"/>
                                        <Button Content="Prices" 
                                                Command="{Binding DataContext.SetProductPricesCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Margin="4"
                                                MinHeight="36"
                                                MinWidth="60"
                                                Padding="4,2"/>
                                        <Button Content="History" 
                                                Command="{Binding DataContext.ShowPaymentHistoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Margin="4"
                                                MinHeight="36"
                                                MinWidth="60"
                                                Padding="4,2"/>
                                        <Button Content="Payment" 
                                                Command="{Binding DataContext.ShowPaymentDialogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding Balance, Converter={StaticResource PaymentButtonVisibilityConverter}}"
                                                Margin="4"
                                                MinHeight="36"
                                                MinWidth="60"
                                                Padding="4,2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Edit Customer" Click="EditMenuItem_Click"/>
                            <MenuItem Header="Set Custom Prices" Command="{Binding SetProductPricesCommand}"/>
                            <MenuItem Header="View Payment History" Command="{Binding ShowPaymentHistoryCommand}"/>
                            <MenuItem Header="Process Payment" 
                                      Command="{Binding ShowPaymentDialogCommand}"
                                      Visibility="{Binding SelectedCustomer.Balance, Converter={StaticResource PaymentButtonVisibilityConverter}}"/>
                            <Separator/>
                            <MenuItem Header="Delete Customer" Click="DeleteMenuItem_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <!-- Error Message Box -->
                <Border Grid.Row="3"
                       Margin="0,10,0,0">
                    <TextBlock Text="{Binding ErrorMessage}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                              Margin="10"/>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="150" Height="8" Margin="0,0,0,14"/>
                <TextBlock Text="Processing..." Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Product Prices Popup -->
        <Popup x:Name="ProductPricesPopup"
               IsOpen="{Binding IsProductPricesDialogOpen, Mode=TwoWay}"
               StaysOpen="True"
               PlacementTarget="{Binding ElementName=CustomerViewRoot}"
               Placement="Center"
               PopupAnimation="Fade"
               AllowsTransparency="True"
               Focusable="True">

            <Grid Background="#80000000" Width="{Binding ActualWidth, ElementName=CustomerViewRoot}" 
                  Height="{Binding ActualHeight, ElementName=CustomerViewRoot}">

                <Border Width="700" Height="500"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Padding="20,15" Background="#333333">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="CUSTOM PRODUCT PRICING" 
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0"/>

                                <Button Grid.Column="1" Content="Close (ESC)" 
                                    Command="{Binding CloseProductPricesDialogCommand}"
                                    Padding="15,10"/>
                            </Grid>
                        </Border>

                        <!-- Customer Info -->
                        <Border Grid.Row="1" Padding="20,15">
                            <StackPanel>
                                <TextBlock>
                                    <Run Text="{Binding SelectedCustomer.Name}"/>
                                </TextBlock>
                                <TextBlock Margin="0,8,0,0">
                                    <Run Text="These prices will only apply to this customer's transactions."/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Product Prices DataGrid -->
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding CustomerProducts}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Margin="20"
                                  RowHeight="48">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product"
                                                   Binding="{Binding ProductName}"
                                                   IsReadOnly="True"
                                                   Width="*"/>

                                <DataGridTextColumn Header="Default Price"
                                                   Binding="{Binding DefaultPrice, StringFormat=C2}"
                                                   IsReadOnly="True"
                                                   Width="140"/>

                                <DataGridTextColumn Header="Custom Price" 
                                                   Binding="{Binding CustomPrice, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="140"/>

                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Reset" 
                                                    Click="ResetPrice_Click"
                                                    MinHeight="36"
                                                    Padding="8,4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer with Buttons -->
                        <Border Grid.Row="3" Padding="20,15">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Cancel"
                                       Command="{Binding CloseProductPricesDialogCommand}"
                                       Margin="0,0,10,0"
                                       MinWidth="120" MinHeight="48"
                                       Padding="8,4"/>
                                    <Button Content="Save Changes"
                                       Command="{Binding SaveCustomPricesCommand}"
                                       MinWidth="160" MinHeight="48"
                                       Padding="8,4"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Popup>

        <!-- Payment Dialog -->
        <Popup IsOpen="{Binding IsPaymentDialogOpen, Mode=TwoWay}"
               StaysOpen="True"
               AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=CustomerViewRoot}"
               Placement="Center"
               PopupAnimation="Fade"
               Focusable="True">

            <Grid Background="#80000000" Width="{Binding ActualWidth, ElementName=CustomerViewRoot}" 
                  Height="{Binding ActualHeight, ElementName=CustomerViewRoot}">

                <Border Width="450"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Padding="20,15" Background="#333333">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="PROCESS PAYMENT" 
                                       Foreground="White"
                                       VerticalAlignment="Center"/>

                                <Button Grid.Column="1" Content="Close (ESC)" 
                                    Command="{Binding ClosePaymentDialogCommand}"
                                    Padding="15,10"/>
                            </Grid>
                        </Border>

                        <!-- Customer Info -->
                        <Border Grid.Row="1" Padding="20,15">
                            <StackPanel>
                                <TextBlock>
                                    <Run Text="{Binding SelectedCustomer.Name}"/>
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0">
                                    <Run Text="Current Balance: "/>
                                    <Run Text="{Binding SelectedCustomer.Balance, StringFormat=C2}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Payment Amount -->
                        <Border Grid.Row="2" Padding="20,20">
                            <StackPanel>
                                <TextBlock Text="Payment Amount:" 
                                      Margin="0,0,0,10"/>
                                <TextBox Text="{Binding PaymentAmount, StringFormat=C2, UpdateSourceTrigger=PropertyChanged}"
                                    MinHeight="42"
                                    Margin="0,0,0,10"/>
                            </StackPanel>
                        </Border>

                        <!-- Footer with Buttons -->
                        <Border Grid.Row="3" Padding="20,15">
                            <Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Cancel"
                                       Command="{Binding ClosePaymentDialogCommand}"
                                       Margin="0,0,10,0"
                                       MinWidth="120" MinHeight="48"
                                       Padding="8,4"/>
                                    <Button Content="Process Payment"
                                       Command="{Binding ProcessPaymentCommand}"
                                       MinWidth="180" MinHeight="48"
                                       Padding="8,4"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Popup>

        <!-- Payment History Dialog -->
        <Popup IsOpen="{Binding IsPaymentHistoryVisible, Mode=TwoWay}"
               StaysOpen="True"
               AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=CustomerViewRoot}"
               Placement="Center"
               PopupAnimation="Fade"
               Focusable="True">

            <Grid Background="#80000000" Width="{Binding ActualWidth, ElementName=CustomerViewRoot}" 
                  Height="{Binding ActualHeight, ElementName=CustomerViewRoot}">

                <Border Width="1000" Height="600"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Padding="20,15" Background="#333333">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding PaymentHistoryTitle, FallbackValue='PAYMENT HISTORY'}" 
                                       Foreground="White"
                                       VerticalAlignment="Center"/>

                                <Button Grid.Column="1" Content="Close (ESC)" 
                                    Command="{Binding ClosePaymentHistoryCommand}"
                                    Padding="15,10"/>
                            </Grid>
                        </Border>

                        <!-- Customer Info -->
                        <Border Grid.Row="1" Padding="20,15">
                            <StackPanel>
                                <TextBlock>
                                    <Run Text="{Binding SelectedCustomer.Name}"/>
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0">
                                    <Run Text="Current Balance: "/>
                                    <Run Text="{Binding SelectedCustomer.Balance, StringFormat=C2}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Date Filter Controls -->
                        <Border Grid.Row="2" Padding="20,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" Content="Filter by Date:" IsChecked="{Binding UseDateFilter}" 
                                      VerticalAlignment="Center" Margin="0,0,15,0"/>

                                <TextBlock Grid.Column="1" Text="From:" VerticalAlignment="Center" Margin="0,0,5,0"
                                       IsEnabled="{Binding UseDateFilter}"/>

                                <DatePicker Grid.Column="2" SelectedDate="{Binding FilterStartDate}" Width="140" Margin="0,0,15,0"
                                        IsEnabled="{Binding UseDateFilter}" MinHeight="42"/>

                                <TextBlock Grid.Column="3" Text="To:" VerticalAlignment="Center" Margin="0,0,5,0"
                                       IsEnabled="{Binding UseDateFilter}"/>

                                <DatePicker Grid.Column="4" SelectedDate="{Binding FilterEndDate}" Width="140" Margin="0,0,15,0"
                                        IsEnabled="{Binding UseDateFilter}" MinHeight="42"/>

                                <Button Grid.Column="5" Content="Apply Filter" Command="{Binding ApplyDateFilterCommand}"
                                    IsEnabled="{Binding UseDateFilter}" 
                                    MinWidth="110" MinHeight="48"
                                    Padding="8,4"/>

                                <Button Grid.Column="7" Content="Update Balance" 
                                    Command="{Binding UpdateCustomerBalanceCommand}"
                                    MinWidth="140" MinHeight="48"
                                    Margin="0,0,10,0"
                                    Padding="8,4"/>

                                <Button Grid.Column="8" Content="Print" 
                                    Command="{Binding PrintPaymentHistoryCommand}"
                                    MinWidth="90" MinHeight="48"
                                    Padding="8,4"/>
                            </Grid>
                        </Border>

                        <!-- Payment History DataGrid -->
                        <DataGrid x:Name="PaymentHistoryGrid" 
                                  Grid.Row="3"
                                  ItemsSource="{Binding PaymentHistory}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Margin="20,15"
                                  RowHeight="48">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date"
                                                   Binding="{Binding TransactionDate, StringFormat=\{0:MM/dd/yyyy HH:mm\}}"
                                                   Width="150"/>
                                <DataGridTextColumn Header="Transaction #"
                                                   Binding="{Binding TransactionId}"
                                                   Width="120"/>
                                <DataGridTextColumn Header="Customer"
                                                   Binding="{Binding CustomerName}"
                                                   Width="180"/>
                                <DataGridTextColumn Header="Type"
                                                   Binding="{Binding TransactionType}"
                                                   Width="120"/>
                                <DataGridTextColumn Header="Amount"
                                                   Binding="{Binding TotalAmount, StringFormat=C2}"
                                                   Width="120"/>
                                <DataGridTextColumn Header="Paid Amount"
                                                   Binding="{Binding PaidAmount, StringFormat=C2}"
                                                   Width="120"/>
                                <DataGridTextColumn Header="Status"
                                                   Binding="{Binding Status}"
                                                   Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer -->
                        <Border Grid.Row="4" Padding="20,15">
                            <Grid>
                                <TextBlock Text="{Binding PaymentHistorySummary}" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>
                                <Button Content="Close"
                                   Command="{Binding ClosePaymentHistoryCommand}"
                                   HorizontalAlignment="Right"
                                   MinWidth="120" MinHeight="48"
                                   Padding="8,4"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Popup>
    </Grid>
</UserControl>