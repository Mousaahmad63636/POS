<UserControl x:Class="QuickTechSystems.WPF.Controls.EmployeeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d"
             MinWidth="450"
             MinHeight="400"
             x:Name="EmployeeEditor">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#007BFF"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#6C757D"/>
        <SolidColorBrush x:Key="TextColor" Color="#343A40"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#28A745"/>
        <SolidColorBrush x:Key="DangerColor" Color="#DC3545"/>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource SecondaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- PasswordBox Style -->
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#F5F5F5" Padding="15">
            <TextBlock Text="{Binding IsNewEmployee, Converter={StaticResource BoolToVisConverter}, ConverterParameter='Add New Employee|Edit Employee'}"
                       FontSize="18"
                       FontWeight="Bold"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="15" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Basic Info Section -->
                <TextBlock Text="Basic Information" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                <!-- Username -->
                <TextBlock Text="{DynamicResource Employee_Username}" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding CurrentEmployee.Username}" Padding="5" Margin="0,0,0,10"/>

                <!-- First Name -->
                <TextBlock Text="{DynamicResource Employee_FirstName}" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding CurrentEmployee.FirstName}" Padding="5" Margin="0,0,0,10"/>

                <!-- Last Name -->
                <TextBlock Text="{DynamicResource Employee_LastName}" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding CurrentEmployee.LastName}" Padding="5" Margin="0,0,0,10"/>

                <!-- Password for new employees -->
                <StackPanel Visibility="{Binding IsNewEmployee, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="{DynamicResource Employee_Password}" FontWeight="Medium" Margin="0,5"/>
                    <PasswordBox x:Name="NewEmployeePasswordBox" Padding="5" Margin="0,0,0,10"/>
                </StackPanel>

                <!-- Role -->
                <TextBlock Text="{DynamicResource Employee_Role}" FontWeight="Medium" Margin="0,5"/>
                <ComboBox ItemsSource="{Binding Roles}"
                         SelectedItem="{Binding CurrentEmployee.Role}"
                         Padding="5" Margin="0,0,0,10"/>

                <!-- Is Active -->
                <CheckBox Content="{DynamicResource Employee_IsActive}"
                         IsChecked="{Binding CurrentEmployee.IsActive}"
                         Margin="0,10,0,20"/>

                <!-- Password Reset Section for existing employees -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewEmployee}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border BorderBrush="{StaticResource BorderColor}" 
                            BorderThickness="1" 
                            Padding="15" 
                            Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Password Reset" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                            <CheckBox Content="Reset Employee Password" 
                                      IsChecked="{Binding IsResetingPassword}"
                                      Margin="0,0,0,10"/>

                            <StackPanel Visibility="{Binding IsResetingPassword, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock Text="New Password" FontWeight="Medium" Margin="0,5"/>
                                <PasswordBox x:Name="ResetPasswordBox" Padding="5" Margin="0,0,0,10"/>

                                <TextBlock Text="Confirm Password" FontWeight="Medium" Margin="0,5"/>
                                <PasswordBox x:Name="ConfirmPasswordBox" Padding="5" Margin="0,0,0,10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with buttons -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Employee_Save}" 
            Command="{Binding SaveCommand}"
            CommandParameter="{Binding ElementName=EmployeeEditor}"
            Width="80"
            Height="30"
            Margin="0,0,10,0"
            Background="#4CAF50"
            Foreground="White"
            BorderThickness="0"/>
                <Button Content="{DynamicResource Employee_Cancel}" 
            Command="{Binding CancelCommand}"
            Width="80"
            Height="30"
            BorderThickness="0"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>