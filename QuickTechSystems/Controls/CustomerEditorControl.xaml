<UserControl x:Class="QuickTechSystems.WPF.Controls.CustomerEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d"
             MinWidth="450"
             MinHeight="400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#F5F5F5" Padding="15">
            <TextBlock Text="Add New Customer"
                       FontSize="18"
                       FontWeight="Bold"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="15" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Customer Name -->
                <TextBlock Text="Customer Name *" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding NewCustomer.Name}" Padding="5" Margin="0,0,0,10"/>

                <!-- Phone -->
                <TextBlock Text="Phone" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding NewCustomer.Phone}" Padding="5" Margin="0,0,0,10"/>

                <!-- Email -->
                <TextBlock Text="Email" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding NewCustomer.Email}" Padding="5" Margin="0,0,0,10"/>

                <!-- Address -->
                <TextBlock Text="Address" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding NewCustomer.Address}"
                         Height="60"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="5"
                         Margin="0,0,0,10"/>

                <!-- Credit Limit -->
                <TextBlock Text="Credit Limit" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding NewCustomer.CreditLimit}" Padding="5" Margin="0,0,0,10"/>

                <!-- Is Active -->
                <CheckBox Content="Customer is Active" 
                          IsChecked="{Binding NewCustomer.IsActive}"
                          Margin="0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with buttons -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" 
                        Command="{Binding SaveCustomerCommand}"
                        Width="80"
                        Height="30"
                        Margin="0,0,10,0"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"/>
                <Button Content="Cancel" 
                        Command="{Binding CancelCustomerCommand}"
                        Width="80"
                        Height="30"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>