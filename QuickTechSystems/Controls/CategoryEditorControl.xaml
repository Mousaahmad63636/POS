<UserControl x:Class="QuickTechSystems.WPF.Controls.CategoryEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d"
             MinWidth="450"
             MinHeight="350">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#F5F5F5" Padding="15">
            <TextBlock Text="{Binding IsAddMode, Converter={StaticResource BoolToVisConverter}, ConverterParameter='Add New Category|Edit Category'}"
                       FontSize="18"
                       FontWeight="Bold"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="15" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Category Name -->
                <TextBlock Text="{DynamicResource Category_Name}" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding SelectedCategory.Name}" Padding="5" Margin="0,0,0,10"/>

                <!-- Description -->
                <TextBlock Text="{DynamicResource Category_Description}" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding SelectedCategory.Description}"
                         Height="100"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="5"
                         Margin="0,0,0,10"/>

                <!-- Is Active -->
                <CheckBox Content="{DynamicResource Category_IsActive}" 
                          IsChecked="{Binding SelectedCategory.IsActive}"
                          Margin="0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with buttons -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource Category_Save}" 
                        Command="{Binding SaveCommand}"
                        Width="80"
                        Height="30"
                        Margin="0,0,10,0"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"/>
                <Button Content="{DynamicResource Category_Cancel}" 
                        Command="{Binding CancelCommand}"
                        Width="80"
                        Height="30"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>