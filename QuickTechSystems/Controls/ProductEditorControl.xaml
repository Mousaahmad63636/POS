<UserControl x:Class="QuickTechSystems.WPF.Controls.ProductEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:QuickTechSystems.WPF.Converters"
             mc:Ignorable="d"
             MinWidth="550"
             MinHeight="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="#F5F5F5" Padding="15">
            <TextBlock Text="{Binding IsAddMode, Converter={StaticResource BoolToVisConverter}, ConverterParameter='Add New Product|Edit Product'}"
                       FontSize="18"
                       FontWeight="Bold"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Margin="15" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Barcode -->
                <TextBlock Text="Barcode" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding SelectedProduct.Barcode}" Padding="5" Margin="0,0,0,10"/>

                <!-- Barcode Generator -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Generate Barcode" 
                            Command="{Binding GenerateBarcodeCommand}"
                            Padding="8,3" Margin="0,0,10,0"/>
                    <Button Content="Auto Generate" 
                            Command="{Binding GenerateAutomaticBarcodeCommand}"
                            Padding="8,3"/>
                </StackPanel>

                <!-- Barcode Image -->
                <Image Source="{Binding BarcodeImage}" 
                       Height="70" 
                       HorizontalAlignment="Left"
                       Margin="0,0,0,15"
                       Stretch="None"/>

                <!-- Product Name -->
                <TextBlock Text="Product Name" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding SelectedProduct.Name}" Padding="5" Margin="0,0,0,10"/>

                <!-- Category -->
                <TextBlock Text="Category" FontWeight="Medium" Margin="0,5"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="CategoryId"
                          SelectedValue="{Binding SelectedProduct.CategoryId}"
                          Margin="0,0,0,10"
                          Padding="5"/>

                <!-- Supplier -->
                <TextBlock Text="Supplier" FontWeight="Medium" Margin="0,5"/>
                <ComboBox ItemsSource="{Binding Suppliers}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="SupplierId"
                          SelectedValue="{Binding SelectedProduct.SupplierId}"
                          Margin="0,0,0,10"
                          Padding="5"/>

                <!-- Description -->
                <TextBlock Text="Description" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding SelectedProduct.Description}"
                         Height="60"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Padding="5"
                         Margin="0,0,0,10"/>

                <!-- Prices -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Purchase Price" FontWeight="Medium" Margin="0,5"/>
                        <TextBox Text="{Binding SelectedProduct.PurchasePrice}" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Sale Price" FontWeight="Medium" Margin="0,5"/>
                        <TextBox Text="{Binding SelectedProduct.SalePrice}" Padding="5"/>
                    </StackPanel>
                </Grid>

                <!-- Stock -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Current Stock" FontWeight="Medium" Margin="0,5"/>
                        <TextBox Text="{Binding SelectedProduct.CurrentStock}" Padding="5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Minimum Stock" FontWeight="Medium" Margin="0,5"/>
                        <TextBox Text="{Binding SelectedProduct.MinimumStock}" Padding="5"/>
                    </StackPanel>
                </Grid>

                <!-- Speed -->
                <TextBlock Text="Speed (Optional)" FontWeight="Medium" Margin="0,5"/>
                <TextBox Text="{Binding SelectedProduct.Speed}" 
                         ToolTip="Enter the speed value (optional)"
                         Padding="5"
                         Margin="0,0,0,10"/>

                <!-- Is Active -->
                <CheckBox Content="Product is Active" 
                          IsChecked="{Binding SelectedProduct.IsActive}"
                          Margin="0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with buttons -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" 
                        Command="{Binding SaveCommand}"
                        Width="80"
                        Height="30"
                        Margin="0,0,10,0"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"/>
                <Button Content="Cancel" 
                        Command="{Binding CancelCommand}"
                        Width="80"
                        Height="30"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>